{%- liquid
  assign heading = section.settings.heading
  assign bg_color = section.settings.background_color | default: '#f7e6d2'
-%}

<div class="vpc-reels-section" style="background: {{ bg_color }};">
  <div class="vpc-reels-inner">

    {%- if heading != blank -%}
      <h2 class="vpc-reels-heading">{{ heading }}</h2>
    {%- endif -%}

    <div class="vpc-reels-slider" id="vpcReelsSlider-{{ section.id }}">
      {%- for block in section.blocks -%}
        {%- if block.type == 'video' -%}
          <div class="vpc-reel-card" {{ block.shopify_attributes }}>
            {%- if block.settings.video_file != blank -%}
              {{ block.settings.video_file | video_tag: autoplay: true, loop: true, muted: true, controls: false, playsinline: true, class: 'vpc-reel-video' }}
            {%- elsif block.settings.video_url != blank -%}
              <video class="vpc-reel-video" autoplay muted loop playsinline>
                <source src="{{ block.settings.video_url }}" type="video/mp4">
              </video>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</div>

<style>
.vpc-reels-section {
  position: relative;
  width: 100vw;
  left: 50%;
  margin-left: -50vw;
  padding: 40px 0 40px;
}
.vpc-reels-inner {
  max-width: 100%;
  overflow: hidden;
}
.vpc-reels-heading {
  text-align: center;
  font-family: 'Poppins', sans-serif;
  font-size: 26px;
  font-weight: 700;
  color: #34150C;
  text-transform: uppercase;
  letter-spacing: 0.03em;
  margin: 0 0 25px 0;
}
.vpc-reels-slider {
  display: flex;
  gap: 14px;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  scrollbar-width: none;
  padding: 0 20px 10px;
  -webkit-overflow-scrolling: touch;
}
.vpc-reels-slider::-webkit-scrollbar {
  display: none;
}
.vpc-reel-card {
  flex: 0 0 auto;
  width: 200px;
  height: 350px;
  border-radius: 8px;
  overflow: hidden;
  scroll-snap-align: start;
  background: #000;
}
.vpc-reel-video {
  width: 100%;
  height: 100%;
  display: block;
  object-fit: cover;
}

@media (min-width: 768px) {
  .vpc-reels-slider {
    padding: 0 40px 10px;
    gap: 20px;
  }
}
@media (min-width: 1024px) {
  .vpc-reels-heading { font-size: 28px; }
  .vpc-reels-slider {
    padding: 0 60px 10px;
    gap: 25px;
  }
}
@media (min-width: 1440px) {
  .vpc-reel-card {
    width: 250px;
    height: 450px;
  }
  .vpc-reels-slider {
    padding: 0 80px 10px;
    gap: 30px;
  }
}
@media (max-width: 767px) {
  .vpc-reels-section { padding: 30px 0; }
  .vpc-reels-heading { font-size: 20px; margin-bottom: 18px; }
  .vpc-reels-slider { padding: 0 12px 10px; gap: 12px; }
}
</style>

{% schema %}
{
  "name": "Reels / Videos",
  "tag": "section",
  "class": "t4s-section t4s-section-all vpc-reels",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Beautiful Ways to Decorate Your Candle"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#f7e6d2"
    }
  ],
  "blocks": [
    {
      "type": "video",
      "name": "Video",
      "limit": 12,
      "settings": [
        {
          "type": "video",
          "id": "video_file",
          "label": "Video (from Files)",
          "info": "Upload via Settings > Files. Overrides URL below."
        },
        {
          "type": "url",
          "id": "video_url",
          "label": "Video URL (fallback)",
          "info": "Direct .mp4/.mov URL. Used if no file selected above."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Reels / Videos"
    }
  ]
}
{% endschema %}
