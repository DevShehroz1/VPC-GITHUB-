{{ 'section.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign sid = section.id
  assign se_stts = section.settings
  assign heading = se_stts.heading | default: 'You May Also Like'
  assign product_1 = se_stts.product_1
  assign product_2 = se_stts.product_2
  assign product_3 = se_stts.product_3
-%}

<div class="vpc-ymal-section vpc-ymal-{{ sid }}">
  <h2 class="vpc-ymal-heading">{{ heading }}</h2>

  {%- assign products_list = '' | split: '' -%}
  {%- if product_1 != blank -%}
    {%- assign products_list = products_list | push: product_1 -%}
  {%- endif -%}
  {%- if product_2 != blank -%}
    {%- assign products_list = products_list | push: product_2 -%}
  {%- endif -%}
  {%- if product_3 != blank -%}
    {%- assign products_list = products_list | push: product_3 -%}
  {%- endif -%}

  {%- if products_list.size > 0 -%}
    <div class="vpc-ymal-list">
      {%- for prod in products_list -%}
        <div class="vpc-ymal-item">
          <a href="{{ prod.url }}" class="vpc-ymal-image-link">
            {%- if prod.featured_image != blank -%}
              <img
                src="{{ prod.featured_image | image_url: width: 200 }}"
                alt="{{ prod.title | escape }}"
                width="120"
                height="120"
                loading="lazy"
                class="vpc-ymal-img"
              >
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'vpc-ymal-placeholder' }}
            {%- endif -%}
          </a>

          <div class="vpc-ymal-info">
            <a href="{{ prod.url }}" class="vpc-ymal-title">{{ prod.title }}</a>

            {%- if prod.metafields.loox.num_reviews and prod.metafields.loox.num_reviews > 0 -%}
              <div class="vpc-ymal-reviews">
                <div class="vpc-ymal-stars">
                  {%- assign avg = prod.metafields.loox.avg_rating | times: 1.0 -%}
                  {%- for i in (1..5) -%}
                    {%- if i <= avg -%}
                      <span class="vpc-star vpc-star-full">&#9733;</span>
                    {%- elsif i == avg | plus: 1 and avg != avg | floor -%}
                      <span class="vpc-star vpc-star-half">&#9733;</span>
                    {%- else -%}
                      <span class="vpc-star vpc-star-empty">&#9734;</span>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
                <span class="vpc-ymal-review-count">{{ prod.metafields.loox.num_reviews }} Reviews</span>
              </div>
            {%- endif -%}

            <div class="vpc-ymal-price">
              {%- if prod.compare_at_price > prod.price -%}
                <span class="vpc-ymal-price-sale">{{ prod.price | money }}</span>
                <span class="vpc-ymal-price-compare">{{ prod.compare_at_price | money }}</span>
              {%- else -%}
                <span class="vpc-ymal-price-regular">{{ prod.price | money }}</span>
              {%- endif -%}
            </div>
          </div>

          <div class="vpc-ymal-action">
            <form method="post" action="/cart/add">
              <input type="hidden" name="id" value="{{ prod.selected_or_first_available_variant.id }}">
              <input type="hidden" name="quantity" value="1">
              <button type="submit" class="vpc-ymal-add-btn">ADD</button>
            </form>
          </div>
        </div>
      {%- endfor -%}
    </div>
  {%- else -%}
    <p style="text-align:center;color:#999;padding:20px;">Select products in the theme customizer.</p>
  {%- endif -%}
</div>

<style>
  .vpc-ymal-section {
    max-width: 100%;
    padding: 30px 20px;
  }
  .vpc-ymal-heading {
    text-align: center;
    font-family: 'Poppins', sans-serif;
    font-size: 22px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #34150C;
    margin: 0 0 25px 0;
  }
  .vpc-ymal-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .vpc-ymal-item {
    display: flex;
    align-items: center;
    gap: 15px;
    padding: 20px 0;
    border-bottom: 1px solid #e8e0d8;
  }
  .vpc-ymal-item:first-child {
    border-top: 1px solid #e8e0d8;
  }
  .vpc-ymal-image-link {
    flex-shrink: 0;
    width: 120px;
    height: 120px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .vpc-ymal-img {
    width: 120px;
    height: 120px;
    object-fit: cover;
    border-radius: 4px;
  }
  .vpc-ymal-placeholder {
    width: 120px;
    height: 120px;
  }
  .vpc-ymal-info {
    flex: 1;
    min-width: 0;
  }
  .vpc-ymal-title {
    display: block;
    font-family: 'Poppins', sans-serif;
    font-size: 15px;
    font-weight: 600;
    color: #34150C;
    text-decoration: none;
    text-transform: uppercase;
    line-height: 1.3;
    margin-bottom: 6px;
  }
  .vpc-ymal-title:hover {
    text-decoration: underline;
  }
  .vpc-ymal-reviews {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-bottom: 6px;
  }
  .vpc-ymal-stars {
    display: flex;
    gap: 1px;
  }
  .vpc-star {
    font-size: 14px;
    color: #34150C;
  }
  .vpc-star-empty {
    color: #ccc;
  }
  .vpc-ymal-review-count {
    font-size: 13px;
    color: #666;
  }
  .vpc-ymal-price {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .vpc-ymal-price-regular,
  .vpc-ymal-price-sale {
    font-size: 15px;
    font-weight: 600;
    color: #34150C;
  }
  .vpc-ymal-price-compare {
    font-size: 14px;
    color: #999;
    text-decoration: line-through;
  }
  .vpc-ymal-action {
    flex-shrink: 0;
  }
  .vpc-ymal-add-btn {
    display: inline-block;
    background: #34150C;
    color: #fff;
    border: none;
    border-radius: 6px;
    padding: 14px 35px;
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 2px;
    cursor: pointer;
    text-transform: uppercase;
    transition: opacity 0.2s;
  }
  .vpc-ymal-add-btn:hover {
    opacity: 0.85;
  }

  /* Mobile */
  @media (max-width: 767px) {
    .vpc-ymal-section {
      padding: 20px 15px;
    }
    .vpc-ymal-heading {
      font-size: 18px;
      margin-bottom: 15px;
    }
    .vpc-ymal-image-link,
    .vpc-ymal-img {
      width: 90px;
      height: 90px;
    }
    .vpc-ymal-title {
      font-size: 13px;
    }
    .vpc-ymal-add-btn {
      padding: 10px 20px;
      font-size: 13px;
    }
    .vpc-ymal-item {
      gap: 10px;
      padding: 15px 0;
    }
  }
</style>

{% schema %}
{
  "name": "You May Also Like",
  "tag": "section",
  "class": "t4s-section t4s-section-all vpc-you-may-also-like",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "You May Also Like"
    },
    {
      "type": "product",
      "id": "product_1",
      "label": "Product 1"
    },
    {
      "type": "product",
      "id": "product_2",
      "label": "Product 2"
    },
    {
      "type": "product",
      "id": "product_3",
      "label": "Product 3"
    }
  ],
  "presets": [
    {
      "name": "You May Also Like"
    }
  ]
}
{% endschema %}
