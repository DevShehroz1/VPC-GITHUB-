        </svg>
      </button>
      <div class="announcement-bar__slider-wrap">
        <div class="announcement-bar__slider" data-section-id="{{ section.id }}">
          <span class="announcement-bar__slide">{{ section.settings.text_1 | default: '🚚 Free Fast Delivery' }}</span>
          <span class="announcement-bar__slide">{{ section.settings.text_3 | default: '⭐ 10,000+ Happy Customers' }}</span>
        </div>
      </div>
      <button type="button" class="announcement-bar__arrow announcement-bar__arrow--right" aria-label="Next">
        <svg class="announcement-bar__arrow-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M9 18l6-6-6-6"/>
        </svg>
      </button>
    </div>
  </div>
</div>

<style>
  .announcement-bar--{{ section.id }} {
    background: var(--ab-bg);
    color: var(--ab-text);
    padding: 12px 24px;
    text-align: center;
    font-size: 14px;
    font-weight: 600;
    overflow: hidden;
    letter-spacing: 0.02em;
  }

  .announcement-bar__desktop {
    display: flex;
    justify-content: space-between;
    align-items: center;
    max-width: 1200px;
    margin: 0 auto;
    gap: 24px;
  }

  .announcement-bar__item {
    flex: 1;
    min-width: 0;
    text-align: center;
  }

  .announcement-bar__item--2,
  .announcement-bar__item--3 {
    border-left: 1px solid rgba(255, 255, 255, 0.5);
    padding-left: 24px;
  }

  .announcement-bar__item--1 {
    text-align: left;
  }
  .announcement-bar__item--2 {
    text-align: center;
  }
  .announcement-bar__item--3 {
    text-align: right;
  }

  /* Mobile: hide desktop, show slider */
  .announcement-bar__mobile {
    display: none;
  }

  @media (max-width: 768px) {
    .announcement-bar--{{ section.id }} {
      padding: 8px 16px;
      font-size: 13px;
    }

    .announcement-bar__desktop {
      display: none;
    }

    .announcement-bar__mobile {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
      position: relative;
    }

    .announcement-bar__slider-wrap {
      flex: 1;
      overflow: hidden;
      min-width: 0;
    }

    .announcement-bar__slider {
      display: flex;
      width: 300%;
      transition: transform 0.35s ease-in-out;
    }

    .announcement-bar__slide {
      flex: 0 0 33.333%;
      width: 33.333%;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      padding: 0 8px;
      box-sizing: border-box;
    }

    .announcement-bar__arrow {
      flex-shrink: 0;
      width: 28px;
      height: 28px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: transparent;
      border: none;
      color: #fff;
      cursor: pointer;
      padding: 0;
      transition: opacity 0.2s, transform 0.2s;
    }

    .announcement-bar__arrow:hover {
      opacity: 0.8;
    }

    .announcement-bar__arrow:active {
      transform: scale(0.95);
    }
  }

  .announcement-bar--{{ section.id }}.announcement-bar--gradient {
    background: linear-gradient(90deg, #E0315E 0%, #E0315E 50%, #E0315E 100%) !important;
  }
</style>

<script>
(function() {
  const sectionId = '{{ section.id }}';
  const slider = document.querySelector('.announcement-bar__slider[data-section-id="' + sectionId + '"]');
  const mobile = document.querySelector('.announcement-bar__mobile');
  if (!slider || !mobile) return;

  const prevBtn = mobile.querySelector('.announcement-bar__arrow--left');
  const nextBtn = mobile.querySelector('.announcement-bar__arrow--right');
  const slides = slider.querySelectorAll('.announcement-bar__slide');
  const total = slides.length;
  let index = 0;
  let autoTimer;

  function goTo(i) {
    index = ((i % total) + total) % total;
    slider.style.transform = 'translateX(-' + (index * 33.333) + '%)';
    resetAuto();
  }

  function next() { goTo(index + 1); }
  function prev() { goTo(index - 1); }

  function resetAuto() {
    clearInterval(autoTimer);
    autoTimer = setInterval(next, 3000);
  }

  if (prevBtn) prevBtn.addEventListener('click', prev);
  if (nextBtn) nextBtn.addEventListener('click', next);

  if (window.matchMedia('(max-width: 768px)').matches) {
    resetAuto();
  }
})();
</script>

{% schema %}
{
  "name": "Announcement bar",
  "tag": "section",
  "class": "section-announcement-bar",
  "settings": [
    {
      "type": "checkbox",
      "id": "use_gradient",
      "label": "Use Valentine gradient",
      "default": true,
      "info": "When off, uses solid background color"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background (when gradient off)",
      "default": "#E0315E"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "text",
      "id": "text_1",
      "label": "Text 1 (Left)",
      "default": "🚚 Free Fast Delivery"
    },
    {
      "type": "text",
      "id": "text_3",
      "label": "Text 3 (Right)",
      "default": "⭐ 10,000+ Happy Customers"
    }
  ],
  "presets": [
    {
      "name": "Announcement bar",
      "settings": {
        "bg_color": "#E0315E",
        "text_color": "#ffffff",
        "text_1": "🚚 Free Fast Delivery",
       
        "text_3": "⭐ 10,000+ Happy Customers"
      }
    }
  ]
}
{% endschema %}
