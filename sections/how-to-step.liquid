{% schema %}
{
  "name": "How to step",
  "settings": [
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Product image"
    },
    {
      "type": "header",
      "content": "Video (used if no image above)"
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "Video URL",
      "default": "https://cdn.shopify.com/videos/c/o/v/ef58b227f20745f6a8d055ef8e715e4c.mp4"
    }
  ],
  "presets": [
    {
      "name": "How to step"
    }
  ]
}
{% endschema %}

<style>
  .how-to-step-section {
    --how-to-accent: #2A2552;
  }
  .how-to-step-section .how-to-img-w {
    border-radius: 16px;
    overflow: hidden;
    background: #c4a574;
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
  }
  .how-to-step-section .how-to-img-w img,
  .how-to-step-section .how-to-img-w video {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .how-to-step-section .h2.how-to {
    color: var(--how-to-accent);
    font-weight: 700;
  }
  .how-to-step-section .h2.how-to .steps-italic {
    font-style: italic;
    font-weight: 400;
  }
  .how-to-step-section .how-to-step {
    display: flex;
    align-items: flex-start;
    gap: 16px;
  }
  .how-to-step-section .how-to-step-i {
    flex-shrink: 0;
  }
</style>

<section class="section gd-beige how-to-step-section">
  <div class="padding-global">
    <div class="w-layout-blockcontainer contain-1140 w-container">
      <div class="spacer-40px"></div>
      <div class="how-to-c">
        <div class="how-to-img-w">
          {% if section.settings.product_image %}
            <img
              src="{{ section.settings.product_image | image_url: width: 800 }}"
              alt="Javvy Coffee Concentrate"
              loading="lazy"
            >
          {% elsif section.settings.video_url != blank %}
            <video style="width:100%;height:100%" muted autoplay loop playsinline>
              <source src="{{ section.settings.video_url }}" type="video/mp4" />
            </video>
          {% else %}
            <div style="min-height: 400px; background: #c4a574; display: flex; align-items: center; justify-content: center; color: rgba(255,255,255,0.5);">Add image or video in theme settings</div>
          {% endif %}
        </div>
        <div class="how-to-txt-w">
          <div class="how-to-h-w">
            <h2 class="h2 how-to">Ready in <br><span class="span-vervaine" style="font-weight: 700;">3</span> <span class="steps-italic span-vervaine">Simple Steps</span></h2>
            <div class="spacer-30px"></div>
            <p class="p-16 c-dark">Javvy reinvented the coffee experience to be <strong>easy, affordable, and extremely tasty!</strong></p>
            <div class="spacer-20px"></div>
          </div>
          <div class="how-to-steps-w">
            <div class="how-to-step">
              <svg xmlns="http://www.w3.org/2000/svg" width="54" height="54" viewBox="0 0 54 54" fill="none" class="how-to-step-i">
                <circle cx="27" cy="27" r="27" fill="#2A2552"/>
                <path d="M19 22h10l2 14H17l2-14z" stroke="white" stroke-width="1.5" fill="none"/>
                <path d="M24 36v4h6v-4" stroke="white" stroke-width="1.5" fill="none"/>
                <circle cx="22" cy="20" r="1" fill="white" opacity="0.8"/>
                <circle cx="26" cy="18" r="0.8" fill="white" opacity="0.8"/>
                <circle cx="30" cy="20" r="1" fill="white" opacity="0.8"/>
              </svg>
              <p class="p-16"><strong>1.</strong> Fill your cup with 6-8 oz of water or milk.</p>
            </div>
            <div class="how-to-step">
              <svg xmlns="http://www.w3.org/2000/svg" width="54" height="54" viewBox="0 0 54 54" fill="none" class="how-to-step-i">
                <circle cx="27" cy="27" r="27" fill="#2A2552"/>
                <path d="M27 14v26M27 14l-8 8M27 14l8 8" stroke="white" stroke-width="1.5" fill="none"/>
                <ellipse cx="27" cy="32" rx="6" ry="2" stroke="white" stroke-width="1.5" fill="none"/>
                <circle cx="20" cy="20" r="1" fill="white" opacity="0.8"/>
                <circle cx="34" cy="22" r="0.8" fill="white" opacity="0.8"/>
                <circle cx="27" cy="16" r="1" fill="white" opacity="0.8"/>
              </svg>
              <p class="p-16"><strong>2.</strong> Mix in 1-2 tsp of Coffee Concentrate.</p>
            </div>
            <div class="how-to-step">
              <svg xmlns="http://www.w3.org/2000/svg" width="54" height="54" viewBox="0 0 54 54" fill="none" class="how-to-step-i">
                <circle cx="27" cy="27" r="27" fill="#2A2552"/>
                <path d="M18 24h14v10c0 2-1 4-3 4H21c-2 0-3-2-3-4V24z" stroke="white" stroke-width="1.5" fill="none"/>
                <path d="M22 24V20c0-2 2-4 5-4s5 2 5 4v4" stroke="white" stroke-width="1.5" fill="none"/>
                <path d="M24 28h6" stroke="white" stroke-width="1.2" fill="none"/>
                <circle cx="20" cy="22" r="1" fill="white" opacity="0.8"/>
                <circle cx="34" cy="24" r="0.8" fill="white" opacity="0.8"/>
                <circle cx="27" cy="18" r="1" fill="white" opacity="0.8"/>
              </svg>
              <p class="p-16"><strong>3.</strong> Top with your favorite creamer, flavoring, or topping. Enjoy!</p>
            </div>
          </div>
        </div>
      </div>
      <div class="spacer-80px"></div>
    </div>
  </div>
</section>
