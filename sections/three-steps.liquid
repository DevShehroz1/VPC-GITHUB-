{% comment %}
  3 Steps Section
  Image on left, title + intro + 3 steps (icon + text) on right
{% endcomment %}

{%- liquid
  assign heading = section.settings.heading
  assign heading_accent = section.settings.heading_accent
  assign intro_text = section.settings.intro_text
  assign image = section.settings.image
  assign video = section.settings.video
  assign video_url = section.settings.video_url
  assign accent_color = section.settings.accent_color
  assign bg_color = section.settings.background_color
-%}

<div class="t4s-three-steps t4s_nt_se_{{ section.id }}" id="shopify-section-{{ section.id }}" style="--t4s-step-accent: {{ accent_color }}; --t4s-step-bg: {{ bg_color }};">
  <div class="t4s-three-steps__inner">
    <div class="t4s-three-steps__grid">
      <div class="t4s-three-steps__image-col">
        <div class="t4s-three-steps__image-wrap">
          {%- if video != blank -%}
            {{ video | video_tag: autoplay: true, loop: true, muted: true, controls: false, image_size: '800x', class: 't4s-three-steps__video' }}
          {%- elsif video_url != blank -%}
            <video class="t4s-three-steps__video" autoplay muted loop playsinline preload="metadata">
              <source src="{{ video_url }}" type="video/mp4">
              <source src="{{ video_url }}" type="video/webm">
              {%- if image != blank -%}<img src="{{ image | image_url: width: 800 }}" alt="{{ image.alt | default: heading | escape }}" loading="lazy">{%- endif -%}
            </video>
          {%- elsif image != blank -%}
            <img
              src="{{ image | image_url: width: 800 }}"
              alt="{{ image.alt | default: heading | escape }}"
              width="800"
              height="600"
              loading="lazy"
              class="t4s-three-steps__img"
            >
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 't4s-three-steps__placeholder' }}
          {%- endif -%}
        </div>
      </div>
      <div class="t4s-three-steps__content-col">
        <header class="t4s-three-steps__header">
          {%- if heading != blank or heading_accent != blank -%}
            <h2 class="t4s-three-steps__title">
              {%- if heading != blank -%}{{ heading }}{%- endif -%}
              {%- if heading_accent != blank and heading_accent != 'Optional accent text' -%} <span class="t4s-three-steps__title-accent">{{ heading_accent }}</span>{%- endif -%}
            </h2>
          {%- else -%}
            <h2 class="t4s-three-steps__title">How to use</h2>
          {%- endif -%}
          {%- if intro_text != blank -%}
            <div class="t4s-three-steps__intro">{{ intro_text }}</div>
          {%- endif -%}
        </header>
        <ul class="t4s-three-steps__list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'step' -%}
              <li class="t4s-three-steps__item" {{ block.shopify_attributes }}>
                <div class="t4s-three-steps__text">
                  <span class="t4s-three-steps__num">{{ forloop.index }}.</span>
                  {%- if block.settings.text != blank -%}{{ block.settings.text }}{%- else -%}Step {{ forloop.index }}{%- endif -%}
                </div>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </div>
    </div>
  </div>
</div>

<style>
  .t4s-three-steps {
    padding: 4rem 1.5rem 5rem;
    background: #FAE9D5;
    font-family: var(--font-body-family, inherit);
    font-size: inherit;
    line-height: inherit;
  }
  .t4s-three-steps__inner {
    max-width: 1100px;
    margin: 0 auto;
  }
  .t4s-three-steps__grid {
    display: grid;
    grid-template-columns: 0.95fr 1.05fr;
    gap: 3.5rem;
    align-items: center;
  }
  .t4s-three-steps__image-wrap {
    border-radius: 8px;
    overflow: hidden;
    background: #e8e4e0;
    border: 2px solid rgba(52, 21, 12, 0.12);
    box-shadow: 0 6px 32px rgba(52, 21, 12, 0.08), 0 2px 8px rgba(0, 0, 0, 0.04);
    aspect-ratio: 1 / 1;
    transition: box-shadow 0.3s ease, transform 0.3s ease;
  }
  .t4s-three-steps__image-wrap:hover {
    box-shadow: 0 12px 40px rgba(52, 21, 12, 0.12), 0 4px 12px rgba(0, 0, 0, 0.06);
    transform: translateY(-2px);
  }
  .t4s-three-steps__img,
  .t4s-three-steps__video,
  .t4s-three-steps__placeholder {
    width: 100%;
    height: 100%;
    display: block;
    vertical-align: middle;
    object-fit: cover;
  }
  .t4s-three-steps__video {
    min-height: 200px;
  }
  .t4s-three-steps__placeholder {
    padding: 2rem;
    min-height: 280px;
  }
  .t4s-three-steps__content-col {
    padding: 0.5rem 0 0.5rem 0.5rem;
  }
  .t4s-three-steps__header {
    margin-bottom: 1.75rem;
  }
  .t4s-three-steps__title {
    font-family: var(--font-heading-family, var(--font-body-family, inherit));
    font-size: clamp(1.35em, 3.2vw, 1.9em);
    font-weight: 700;
    color: #2c2c2c;
    line-height: 1.25;
    margin: 0 0 0.6em;
    letter-spacing: -0.02em;
  }
  .t4s-three-steps__title-accent {
    font-style: italic;
    font-weight: 500;
    color: var(--t4s-step-accent, #34150C);
  }
  .t4s-three-steps__intro {
    font-size: 1em;
    color: #555;
    line-height: 1.65;
    margin-bottom: 0;
  }
  .t4s-three-steps__intro strong {
    font-weight: 600;
    color: #333;
  }
  .t4s-three-steps__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .t4s-three-steps__item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.9rem 1.1rem;
    background: rgba(255, 255, 255, 0.6);
    border-radius: 8px;
    border-left: 4px solid var(--t4s-step-accent, #34150C);
    box-shadow: 0 2px 8px rgba(52, 21, 12, 0.04);
    transition: background 0.2s ease, box-shadow 0.2s ease;
  }
  .t4s-three-steps__item:hover {
    background: rgba(255, 255, 255, 0.85);
    box-shadow: 0 4px 16px rgba(52, 21, 12, 0.06);
  }
  .t4s-three-steps__text {
    font-size: 1em;
    color: #444;
    line-height: 1.55;
    padding-top: 0;
  }
  .t4s-three-steps__num {
    font-weight: 700;
    color: var(--t4s-step-accent, #34150C);
    margin-right: 0.35rem;
  }
  @media (max-width: 768px) {
    .t4s-three-steps {
      padding: 3rem 1.25rem 4rem;
    }
    .t4s-three-steps__grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .t4s-three-steps__image-wrap {
      aspect-ratio: auto;
      border-radius: 6px;
    }
    .t4s-three-steps__image-wrap:hover {
      transform: none;
    }
    .t4s-three-steps__img,
    .t4s-three-steps__video {
      height: auto;
      object-fit: contain;
    }
    .t4s-three-steps__content-col {
      padding: 0;
    }
    .t4s-three-steps__header {
      margin-bottom: 1.5rem;
    }
    .t4s-three-steps__item {
      padding: 0.75rem 1rem;
    }
    .t4s-three-steps__image-col {
      order: 1;
    }
    .t4s-three-steps__content-col {
      order: 2;
    }
  }
</style>

{% schema %}
{
  "name": "3 Steps",
  "tag": "section",
  "class": "t4s-section-three-steps",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image or GIF (left side)",
      "info": "Supports JPG, PNG, GIF, WebP. Use video URL below for video."
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video (optional)",
      "info": "Paste or pick video from Files. Overrides image when set."
    },
    {
      "type": "text",
      "id": "video_url",
      "label": "Video URL (optional)",
      "info": "External .mp4 or .webm URL. Used if no video selected above."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading (first part)",
      "default": "How to use"
    },
    {
      "type": "text",
      "id": "heading_accent",
      "label": "Heading accent (script/italic part)",
      "default": "Optional accent text"
    },
    {
      "type": "richtext",
      "id": "intro_text",
      "label": "Intro text",
      "default": "<p>Reinvented the experience to be <strong>easy, affordable, and extremely tasty!</strong></p>"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color (icons, accent text)",
      "default": "#34150C"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FAE9D5"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "limit": 12,
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Step text",
          "default": "Pour wax pearls into your holder."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "3 Steps",
      "blocks": [
        {
          "type": "step",
          "settings": { "text": "Pour wax pearls into your holder." }
        },
        {
          "type": "step",
          "settings": { "text": "Insert the wick upright." }
        },
        {
          "type": "step",
          "settings": { "text": "Add a few drops of oil." }
        },
        {
          "type": "step",
          "settings": { "text": "Light and enjoy the glow." }
        }
      ]
    }
  ]
}
{% endschema %}
