{%- liquid
  assign heading = section.settings.heading | default: 'What is included'
  assign bg_color = section.settings.background_color | default: '#ffffff'
  assign text_color = section.settings.text_color | default: '#3d1b00'
  assign item_1_label = section.settings.item_1_label | default: 'Candle'
  assign item_1_image = section.settings.item_1_image
  assign item_1_use_metafield = section.settings.item_1_use_metafield
  assign item_2_label = section.settings.item_2_label | default: 'Wicks'
  assign item_2_image = section.settings.item_2_image
-%}

<section class="vpc-wi-section" style="background: {{ bg_color }};">
  <div class="vpc-wi-container">
    <h2 class="vpc-wi-heading" style="color: {{ text_color }};">{{ heading }}</h2>

    <div class="vpc-wi-row">
      <!-- Item 1 -->
      <div class="vpc-wi-item">
        <div class="vpc-wi-img-wrap">
          {%- if item_1_use_metafield and product.metafields.custom.image != blank -%}
            <img src="{{ product.metafields.custom.image | image_url: width: 600 }}" alt="{{ item_1_label | escape }}" loading="lazy">
          {%- elsif item_1_image != blank -%}
            <img src="{{ item_1_image | image_url: width: 600 }}" alt="{{ item_1_label | escape }}" loading="lazy">
          {%- else -%}
            {{ 'product-1' | placeholder_svg_tag: 'vpc-wi-placeholder' }}
          {%- endif -%}
        </div>
        <p class="vpc-wi-label" style="color: {{ text_color }};">{{ item_1_label }}</p>
      </div>

      <!-- Plus Sign -->
      <span class="vpc-wi-plus" style="color: {{ text_color }};">+</span>

      <!-- Item 2 -->
      <div class="vpc-wi-item">
        <div class="vpc-wi-img-wrap">
          {%- if item_2_image != blank -%}
            <img src="{{ item_2_image | image_url: width: 600 }}" alt="{{ item_2_label | escape }}" loading="lazy">
          {%- else -%}
            {{ 'product-2' | placeholder_svg_tag: 'vpc-wi-placeholder' }}
          {%- endif -%}
        </div>
        <p class="vpc-wi-label" style="color: {{ text_color }};">{{ item_2_label }}</p>
      </div>
    </div>
  </div>
</section>

<style>
.vpc-wi-section {
  padding: 40px 20px;
}
.vpc-wi-container {
  max-width: 700px;
  margin: 0 auto;
  text-align: center;
}
.vpc-wi-heading {
  font-family: 'Poppins', sans-serif;
  font-size: 28px;
  font-weight: 700;
  margin: 0 0 30px 0;
}
.vpc-wi-row {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 15px;
}
.vpc-wi-item {
  flex: 1;
  max-width: 280px;
}
.vpc-wi-img-wrap {
  width: 100%;
  aspect-ratio: 1/1;
  overflow: hidden;
  border-radius: 8px;
  background: rgba(52, 21, 12, 0.04);
}
.vpc-wi-img-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.vpc-wi-label {
  font-family: 'Poppins', sans-serif;
  font-size: 16px;
  font-weight: 600;
  margin: 10px 0 0;
}
.vpc-wi-plus {
  font-size: 24px;
  font-weight: 300;
  flex-shrink: 0;
  opacity: 0.6;
}
.vpc-wi-placeholder {
  width: 100%;
  height: 100%;
}

@media (max-width: 767px) {
  .vpc-wi-section { padding: 30px 16px; }
  .vpc-wi-heading { font-size: 22px; margin-bottom: 20px; }
  .vpc-wi-row { gap: 8px; }
  .vpc-wi-item { max-width: none; }
  .vpc-wi-plus { font-size: 18px; }
  .vpc-wi-label { font-size: 14px; }
}
</style>

{% schema %}
{
  "name": "What is Included",
  "tag": "section",
  "class": "t4s-section t4s-section-all vpc-what-included",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What is included"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#3d1b00"
    },
    {
      "type": "header",
      "content": "Item 1"
    },
    {
      "type": "text",
      "id": "item_1_label",
      "label": "Label",
      "default": "Candle"
    },
    {
      "type": "checkbox",
      "id": "item_1_use_metafield",
      "label": "Use product metafield image",
      "default": true,
      "info": "Uses product.metafields.custom.image if available"
    },
    {
      "type": "image_picker",
      "id": "item_1_image",
      "label": "Fallback Image",
      "info": "Used when metafield is disabled or empty"
    },
    {
      "type": "header",
      "content": "Item 2"
    },
    {
      "type": "text",
      "id": "item_2_label",
      "label": "Label",
      "default": "Wicks"
    },
    {
      "type": "image_picker",
      "id": "item_2_image",
      "label": "Image"
    }
  ],
  "presets": [
    {
      "name": "What is Included"
    }
  ]
}
{% endschema %}
