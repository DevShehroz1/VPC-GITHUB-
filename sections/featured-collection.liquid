        {%- comment -%} Collect product badge data {%- endcomment -%}
        {%- capture product_badges -%}
          [
            {%- for product in collection.products -%}
              {%- assign limited_stock_metafield = product.metafields.custom.limited_stock -%}
              {%- assign limited_stock_image = null -%}
              {%- if limited_stock_metafield -%}
                {%- if limited_stock_metafield.value -%}
                  {%- assign limited_stock_image = limited_stock_metafield.value | img_url: 'master' -%}
                {%- elsif limited_stock_metafield.src -%}
                  {%- assign limited_stock_image = limited_stock_metafield.src -%}
                {%- else -%}
                  {%- assign limited_stock_image = limited_stock_metafield | img_url: 'master' -%}
                {%- endif -%}
              {%- endif -%}
              {
                "id": {{ product.id }},
                "handle": "{{ product.handle }}",
                "badge": {% if limited_stock_image %}"{{ limited_stock_image }}"{% else %}null{% endif %}
              }{% unless forloop.last %},{% endunless %}
            {%- endfor -%}
          ]
        {%- endcapture -%}
        <script>
          (function() {
            var badges = {{ product_badges }};
            var sectionId = '{{ sid }}';
            var productsContainer = document.querySelector('#shopify-section-' + sectionId + ' .t4s-products');
            if (!productsContainer || !badges || badges.length === 0) return;
            
            function addBadges() {
              var productItems = productsContainer.querySelectorAll('.t4s-product, .t4s-col-item');
              productItems.forEach(function(item, index) {
                if (item.querySelector('.limited-stock-badge')) return;
                
                var productId = null;
                var productHandle = null;
                
                productId = item.getAttribute('data-product-id') || 
                           item.getAttribute('data-id');
                
                if (!productId) {
                  var productLink = item.querySelector('a[href*="/products/"]');
                  if (productLink) {
                    var href = productLink.getAttribute('href');
                    var match = href.match(/\/products\/([^\/\?]+)/);
                    if (match) {
                      productHandle = match[1];
                    }
                  }
                }
                
                var badgeData = null;
                if (productId) {
                  badgeData = badges.find(function(b) { 
                    return String(b.id) === String(productId);
                  });
                }
                
                if (!badgeData && productHandle) {
                  badgeData = badges.find(function(b) { 
                    return b.handle === productHandle;
                  });
                }
                
                if (!badgeData && index < badges.length && badges[index].badge) {
                  badgeData = badges[index];
                }
                
                if (badgeData && badgeData.badge) {
                  var badge = document.createElement('div');
                  badge.className = 'limited-stock-badge';
                  badge.innerHTML = '<img src="' + badgeData.badge + '" alt="Limited Stock">';
                  if (!item.style.position || item.style.position === 'static') {
                    item.style.position = 'relative';
                  }
                  item.appendChild(badge);
                }
              });
            }
            
            function initBadges() {
              if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', addBadges);
              } else {
                setTimeout(addBadges, 100);
              }
            }
            
            initBadges();
            
            if (typeof MutationObserver !== 'undefined') {
              var observer = new MutationObserver(function(mutations) {
                var shouldAdd = false;
                mutations.forEach(function(mutation) {
                  if (mutation.addedNodes.length > 0) {
                    shouldAdd = true;
                  }
                });
                if (shouldAdd) {
                  setTimeout(addBadges, 50);
                }
              });
              observer.observe(productsContainer, { childList: true, subtree: true });
            }
          })();
        </script>

