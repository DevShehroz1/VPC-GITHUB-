{%- liquid
  assign sid = section.id
  assign se_stts = section.settings
  assign se_blocks = section.blocks
  assign stt_layout = se_stts.layout
  assign stt_image_bg = se_stts.image_bg
  if stt_layout == 't4s-se-container' 
    assign html_layout = '<div class="t4s-container">__</div></div>' | split: '__'
  elsif stt_layout == 't4s-container-wrap'
    assign html_layout = '<div class="t4s-container">__</div>' | split: '__'
  else
    assign html_layout = '__' | split: '__'
  endif
  assign layout_des = se_stts.layout_des
  assign image_ratio = se_stts.image_ratio
  if image_ratio == "ratioadapt"
    assign imgatt = ''
   else 
    assign imgatt = 'data-'
  endif
  assign collection = collections[se_stts.collection]
  assign use_pagination = se_stts.use_pagination 
  assign sett_equal = se_stts.use_eq_height
  assign show_vendor = se_stts.show_vendor
  assign use_link_vendor = settings.use_link_vendor
  assign placeholder_img = settings.placeholder_img
  assign enable_rating = settings.enable_rating
  assign app_review = settings.app_review
  assign inc_pr = se_stts.pr_des
  assign limit = se_stts.limit
  assign product_des = se_stts.product_des
  if se_stts.btn_owl == "outline"
    assign arrow_icon = 1
  else
    assign arrow_icon = 2
  endif

  assign show_img = settings.show_img
  assign isGrowaveWishlist = false
  if settings.wishlist_mode == "3" and shop.customer_accounts_enabled
    assign isGrowaveWishlist = true
  endif
  assign enable_pr_size = settings.enable_pr_size
  assign pr_size_pos = settings.pr_size_pos
  assign show_size_type = settings.show_size_type
  assign size_ck = settings.size_ck | append: ',size,sizes,Größe' 
  assign get_size = size_ck | downcase | replace: ' ,', ',' | replace: ', ', ',' | split: ',' | uniq

  assign enable_pr_color = settings.enable_pr_color
  assign show_cl_type = '1'
  assign color_ck = settings.color_ck | append: ',color,colors,couleur,colour'
  assign get_color = color_ck | downcase | replace: ' ,', ',' | replace: ', ', ',' | split: ',' | uniq

  assign price_varies_style = settings.price_varies_style
  assign use_countdown = se_stts.use_cdt

  
  assign txt_cd = 'products.grid_items.offer_end_in' | t
  
  assign isLoadmore = false
  if layout_des != "3"
    if use_pagination == "load-more"
      assign isLoadmore = true
      assign typeAjax = 'LmDefault'
    else
      assign typeAjax = 'AjaxDefault'
    endif
  else
     if use_pagination == "load-more"
      assign isLoadmore = true
      assign typeAjax = 'LmIsotope'
    else
      assign typeAjax = 'AjaxIsotope'
    endif
  endif
  
  assign enable_bar_lm = se_stts.enable_bar_lm 
  assign results_count = collection.products_count 

  assign t4s_se_class = 't4s_nt_se_' | append: sid
  if se_stts.use_cus_css and se_stts.code_cus_css != blank
    render 'se_cus_css', code_cus_css: se_stts.code_cus_css, t4s_se_class: t4s_se_class
  endif 
  if section.settings.center_slide
  echo 't4s-carousel-center.css' | asset_url | stylesheet_tag
  endif
-%}
<style>
  #shopify-section-{{ sid }} .t4s-products .t4s-product,
  #shopify-section-{{ sid }} .t4s-products .t4s-col-item {
    position: relative;
  }

  #shopify-section-{{ sid }} .t4s-products .t4s-product .limited-stock-badge,
  #shopify-section-{{ sid }} .t4s-products .t4s-col-item .limited-stock-badge {
    position: absolute;
    top: 0.75rem;
    right: calc(0.75rem + 1px);
    width: clamp(5rem, 18vw, 8rem);
    aspect-ratio: 1 / 1;
    pointer-events: none;
    z-index: 10;
    filter: drop-shadow(0 4px 12px rgba(0, 0, 0, 0.25));
  }

  #shopify-section-{{ sid }} .t4s-products .t4s-product .limited-stock-badge img,
  #shopify-section-{{ sid }} .t4s-products .t4s-col-item .limited-stock-badge img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  @media (max-width: 480px) {
    #shopify-section-{{ sid }} .t4s-products .t4s-product .limited-stock-badge,
    #shopify-section-{{ sid }} .t4s-products .t4s-col-item .limited-stock-badge {
      top: 0.5rem;
      right: calc(0.5rem + 1px);
      width: clamp(4rem, 35vw, 6.5rem);
    }
  }

  /* Noon.com Style Product Features */
  #shopify-section-{{ sid }} .t4s-product-info .noon-product-features {
    margin-top: 0.1rem;
    margin-bottom: 0.1rem;
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
    min-height: 1.2rem;
    font-size: 0.875rem;
    line-height: 1.2;
    font-family: 'Poppins', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }

  #shopify-section-{{ sid }} .t4s-product-info .noon-product-features .noon-feature-item {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 0.375rem;
    color: #000;
    opacity: 0;
    transform: translateX(-50%) translateY(10px);
    transition: opacity 0.4s ease-out, transform 0.4s ease-out;
    pointer-events: none;
    left: 50%;
    white-space: nowrap;
    font-family: 'Poppins', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    font-weight: 500;
  }

  #shopify-section-{{ sid }} .t4s-product-info .noon-product-features .noon-feature-item.noon-active {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  #shopify-section-{{ sid }} .t4s-product-info .noon-product-features .noon-feature-item.noon-slide-out {
    opacity: 0;
    transform: translateX(-50%) translateY(-10px);
  }

  #shopify-section-{{ sid }} .t4s-product-info .noon-product-features .noon-feature-item.noon-free-delivery {
    color: #000;
  }

  #shopify-section-{{ sid }} .t4s-product-info .noon-product-features .noon-feature-item.noon-limited-stock {
    color: #000;
  }

  #shopify-section-{{ sid }} .t4s-product-info .noon-product-features .noon-feature-item.noon-stock-count {
    color: #000;
  }

  #shopify-section-{{ sid }} .t4s-product-info .noon-product-features .noon-feature-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  #shopify-section-{{ sid }} .t4s-product-info .noon-product-features .noon-feature-icon svg {
    width: 100%;
    height: 100%;
    fill: currentColor;
  }

  #shopify-section-{{ sid }} .t4s-product-info .noon-product-features .noon-feature-icon .noon-icon-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  #shopify-section-{{ sid }} .t4s-product-info .noon-product-features .noon-feature-text {
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    #shopify-section-{{ sid }} .t4s-product-info .noon-product-features {
      font-size: 0.8125rem;
      gap: 0.5rem;
      margin-top: 0.1rem;
      margin-bottom: 0.1rem;
      min-height: 1.1rem;
    }
    
    #shopify-section-{{ sid }} .t4s-product-info .noon-product-features .noon-feature-icon {
      width: 14px;
      height: 14px;
    }
  }
</style>

