                "variants": [
                  {%- for variant in product.variants -%}
                    {
                      "id": {{ variant.id }},
                      "inventory_quantity": {{ variant.inventory_quantity | default: 0 }},
                      "inventory_management": "{{ variant.inventory_management }}",
                      "inventory_policy": "{{ variant.inventory_policy }}",
                      "available": {{ variant.available }}
                    }{% unless forloop.last %},{% endunless %}
                  {%- endfor -%}
                ],
                "free_delivery": {% if product.metafields.custom.free_delivery == true or product.metafields.custom.free_delivery == 'true' %}true{% else %}false{% endif %},
                "limited_stock": {% if product.metafields.custom.limited_stock == true or product.metafields.custom.limited_stock == 'true' %}true{% else %}false{% endif %},
                "stock_threshold": {{ product.metafields.custom.stock_threshold | default: 10 }}
              }{% unless forloop.last %},{% endunless %}
            {%- endfor -%}
          ]
        {%- endcapture -%}

        <script>
          (function() {
            var productsData = {{ product_features_data }};
            var sectionId = '{{ sid }}';
            var sectionSettings = {
              enableFreeDelivery: {% if se_stts.enable_free_delivery %}true{% else %}false{% endif %},
              enableLimitedStock: {% if se_stts.enable_limited_stock %}true{% else %}false{% endif %},
              enableStockCount: {% if se_stts.enable_stock_count %}true{% else %}false{% endif %},
              stockThreshold: {{ se_stts.stock_threshold | default: 10 }}
            };
            var productsContainer = document.querySelector('#shopify-section-' + sectionId + ' .t4s-products');
            if (!productsContainer || !productsData || productsData.length === 0) return;

            // Image Icons (Noon.com style)
            var deliveryIcon = '<img src="https://cdn.shopify.com/s/files/1/0920/7591/7591/files/77701d64-1162-4836-93f9-584b39add4fd.avif?v=1766177514" alt="Delivery" class="noon-icon-img">';
            var limitedStockIcon = '<img src="https://cdn.shopify.com/s/files/1/0920/7591/7591/files/d2809d6f-556e-414a-b0f9-51cef68684bc.avif?v=1766177513" alt="Limited Stock" class="noon-icon-img">';
            var stockCountIcon = '<img src="https://cdn.shopify.com/s/files/1/0920/7591/7591/files/bbe527b1-1a11-432b-ab8c-967aef1f011e.avif?v=1766177514" alt="Stock" class="noon-icon-img">';

            function getTotalInventory(productData) {
              var total = 0;
              if (productData.variants && productData.variants.length > 0) {
                productData.variants.forEach(function(variant) {
                  if (variant.inventory_management && variant.inventory_management !== 'null') {
                    total += variant.inventory_quantity || 0;
                  }
                });
              }
              return total;
            }

            function addNoonFeatures() {
              var productItems = productsContainer.querySelectorAll('.t4s-product, .t4s-col-item');
              productItems.forEach(function(item, index) {
                // Skip if already processed
                if (item.querySelector('.noon-product-features')) return;

                var productId = null;
                var productHandle = null;
                var productLink = item.querySelector('a[href*="/products/"]');
                
                if (productLink) {
                  var href = productLink.getAttribute('href');
                  var match = href.match(/\/products\/([^\/\?]+)/);
                  if (match) {
                    productHandle = match[1];
                  }
                }

                productId = item.getAttribute('data-product-id') || 
                           item.getAttribute('data-id');

                // Find product data
                var productData = null;
                if (productId) {
                  productData = productsData.find(function(p) { 
                    return String(p.id) === String(productId);
                  });
                }
                
                if (!productData && productHandle) {
                  productData = productsData.find(function(p) { 
                    return p.handle === productHandle;
                  });
                }

                if (!productData && index < productsData.length) {
                  productData = productsData[index];
                }

                if (!productData) return;

                // Find product title element
                var productInfo = item.querySelector('.t4s-product-info, .t4s-product-info__inner');
                if (!productInfo) return;

                var titleElement = productInfo.querySelector('.t4s-product-title, h3, h2, h1, .product-title');
                if (!titleElement) return;

                // Create features container
                var featuresContainer = document.createElement('div');
                featuresContainer.className = 'noon-product-features';

                // Get total inventory first (needed for stock count and limited stock)
                var totalStock = getTotalInventory(productData);
                var stockThreshold = productData.stock_threshold || sectionSettings.stockThreshold;

                // 1. Stock Count (FIRST - show real inventory)
                if (sectionSettings.enableStockCount && totalStock > 0 && productData.available) {
                  var stockCount = document.createElement('div');
                  stockCount.className = 'noon-feature-item noon-stock-count';
                  stockCount.innerHTML = '<span class="noon-feature-icon">' + stockCountIcon + '</span><span class="noon-feature-text">' + totalStock + ' in stock</span>';
                  featuresContainer.appendChild(stockCount);
                }

                // 2. Free Delivery (SECOND)
                if (sectionSettings.enableFreeDelivery) {
                  var showFreeDelivery = productData.free_delivery;
                  if (showFreeDelivery === undefined || showFreeDelivery === null) {
                    showFreeDelivery = true; // Default to showing free delivery for all products
                  }
                  
                  if (showFreeDelivery) {
                    var freeDelivery = document.createElement('div');
                    freeDelivery.className = 'noon-feature-item noon-free-delivery';
                    freeDelivery.innerHTML = '<span class="noon-feature-icon">' + deliveryIcon + '</span><span class="noon-feature-text">Free Delivery</span>';
                    featuresContainer.appendChild(freeDelivery);
                  }
                }

                // 3. Limited Stock (THIRD)
                if (sectionSettings.enableLimitedStock && (productData.limited_stock || (totalStock > 0 && totalStock <= stockThreshold))) {
                  var limitedStock = document.createElement('div');
                  limitedStock.className = 'noon-feature-item noon-limited-stock';
                  limitedStock.innerHTML = '<span class="noon-feature-icon">' + limitedStockIcon + '</span><span class="noon-feature-text">Limited Stock</span>';
                  featuresContainer.appendChild(limitedStock);
                }

                // Insert before title and initialize rotation
                if (featuresContainer.children.length > 0) {
                  titleElement.parentNode.insertBefore(featuresContainer, titleElement);
                  // Initialize rotation for this product
                  initFeatureRotation(featuresContainer);
                }
              });
            }

            function initFeatureRotation(container) {
              var features = Array.from(container.querySelectorAll('.noon-feature-item'));
              if (features.length === 0) return;
              
              var currentIndex = 0;
              
              // Show first feature after a small delay
              setTimeout(function() {
                if (features.length > 0) {
                  features[0].classList.add('noon-active');
                }
              }, 100);
              
              // If only one feature, no need to rotate
              if (features.length <= 1) return;
              
              function rotateFeatures() {
                // Remove active class from current
                features[currentIndex].classList.remove('noon-active');
                features[currentIndex].classList.add('noon-slide-out');
                
                // Move to next feature
                currentIndex = (currentIndex + 1) % features.length;
                
                // After slide-out animation, show next feature
                setTimeout(function() {
                  // Remove slide-out from all
                  features.forEach(function(feature) {
                    feature.classList.remove('noon-slide-out');
                  });
                  
                  // Show next feature
                  features[currentIndex].classList.add('noon-active');
                }, 400); // Match transition duration
              }
              
              // Start rotation after 4 seconds (4000ms)
              var rotationInterval = setInterval(rotateFeatures, 4000);
              
              // Store interval ID on container for potential cleanup
              container.dataset.rotationInterval = rotationInterval;
            }

            function initNoonFeatures() {
              if (document.readyState === 'loading') {
                document.addEventListener('DOMContentLoaded', addNoonFeatures);
              } else {
                setTimeout(addNoonFeatures, 100);
              }
            }

            initNoonFeatures();

            // Watch for new products added dynamically
            if (typeof MutationObserver !== 'undefined') {
              var observer = new MutationObserver(function(mutations) {
                var shouldAdd = false;
                mutations.forEach(function(mutation) {
                  if (mutation.addedNodes.length > 0) {
                    shouldAdd = true;
                  }
                });
                if (shouldAdd) {
                  setTimeout(addNoonFeatures, 50);
                }
              });
              observer.observe(productsContainer, { childList: true, subtree: true });
            }
          })();
        </script>
    {%- else -%}
