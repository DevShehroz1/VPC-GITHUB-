<script>
(function() {
  const sectionId = 'sections--25922892398972__custom_timer_christmas_tmXmJ4';

  // End date: February 16, 2026 at 11:59:59 PM PST
  // Create date in PST (UTC-8) by manually setting the time
  const targetDate = new Date('2026-02-16T23:59:59-08:00').getTime();

  // Get timer elements
  const daysEl = document.getElementById('timer-' + sectionId + '-days');
  const hoursEl = document.getElementById('timer-' + sectionId + '-hours');
  const minutesEl = document.getElementById('timer-' + sectionId + '-minutes');
  const secondsEl = document.getElementById('timer-' + sectionId + '-seconds');
  const timerSection = document.getElementById('timer-section-' + sectionId);
  const timerContainer = document.getElementById('timer-' + sectionId);

  // Subtle pulse animation for time blocks
  function pulseTimeBlock(element) {
    if (element && element.parentElement) {
      const block = element.parentElement;
      block.style.transition = 'all 0.2s ease';
      block.style.transform = 'scale(1.05)';
      setTimeout(() => {
        block.style.transform = '';
      }, 200);
    }
  }

  let lastSeconds = -1;
  let lastMinutes = -1;
  let lastHours = -1;
  let lastDays = -1;
  let timerInterval = null;

  function updateTimer() {
    const now = new Date().getTime();
    let distance = targetDate - now;

    if (distance < 0) {
      if (timerSection) {
        timerSection.style.display = "none";
      }
      if (timerInterval) {
        clearInterval(timerInterval);
      }
      return;
    }

    const days = Math.floor(distance / (1000 * 60 * 60 * 24));
    const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
    const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
    const seconds = Math.floor((distance % (1000 * 60)) / 1000);

    // Update display with zero padding
    if (daysEl) {
      const daysStr = String(days).padStart(2, '0');
      if (daysEl.textContent !== daysStr) {
        daysEl.textContent = daysStr;
        if (lastDays !== -1 && lastDays !== days) {
          pulseTimeBlock(daysEl);
        }
      }
      lastDays = days;
    }

    if (hoursEl) {
      const hoursStr = String(hours).padStart(2, '0');
      if (hoursEl.textContent !== hoursStr) {
        hoursEl.textContent = hoursStr;
        if (lastHours !== -1 && lastHours !== hours) {
          pulseTimeBlock(hoursEl);
        }
      }
      lastHours = hours;
    }

    if (minutesEl) {
      const minutesStr = String(minutes).padStart(2, '0');
      if (minutesEl.textContent !== minutesStr) {
        minutesEl.textContent = minutesStr;
        if (lastMinutes !== -1 && lastMinutes !== minutes) {
          pulseTimeBlock(minutesEl);
        }
      }
      lastMinutes = minutes;
    }

    if (secondsEl) {
      const secondsStr = String(seconds).padStart(2, '0');
      if (secondsEl.textContent !== secondsStr) {
        secondsEl.textContent = secondsStr;
        // Subtle pulse only on minute transitions
        if (seconds === 0) {
          pulseTimeBlock(secondsEl);
        }
      }
      lastSeconds = seconds;
    }

    // Subtle urgency effect when less than 24 hours remain
    if (days === 0 && hours < 24 && timerSection) {
      timerSection.style.borderColor = 'rgba(255, 255, 255, 0.25)';
      timerSection.style.boxShadow = '0 4px 24px rgba(0, 0, 0, 0.3), 0 0 0 1px rgba(255, 255, 255, 0.15), inset 0 1px 0 rgba(255, 255, 255, 0.15)';
    }

    // Enhanced effect when less than 1 hour remains
    if (days === 0 && hours === 0 && minutes < 60) {
      if (timerSection) {
        timerSection.style.borderColor = 'rgba(255, 255, 255, 0.35)';
        timerSection.style.boxShadow = '0 6px 28px rgba(0, 0, 0, 0.35), 0 0 0 1px rgba(255, 255, 255, 0.2), inset 0 1px 0 rgba(255, 255, 255, 0.2)';
      }
    }
  }

  // Wait for DOM to be ready, then initialize timer
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', function() {
      updateTimer();
      timerInterval = setInterval(updateTimer, 1000);
    });
  } else {
    updateTimer();
    timerInterval = setInterval(updateTimer, 1000);
  }
})();
</script>

