            "custom_liquid": "<style>\n/* ===== ENHANCED BUNDLE BUILDER ===== */\n.vpc-bld { margin-top: 20px; font-family: 'Poppins', sans-serif; }\n.vpc-bld__header { margin-bottom: 18px; }\n.vpc-bld__label {\n  font-size: 18px; font-weight: 800; color: #34150C;\n  margin: 0 0 4px; text-transform: uppercase; letter-spacing: 0.02em;\n}\n.vpc-bld__sublabel {\n  font-size: 13px; color: #888; font-weight: 400; margin: 0;\n}\n\n/* ===== PROGRESS BAR TIER SELECTOR ===== */\n.vpc-bld__tiers {\n  position: relative; margin-bottom: 10px;\n  padding: 16px 20px 12px; background: #fdfbf9;\n  border: 1.5px solid #e8e0da; border-radius: 14px;\n}\n.vpc-bld__progress-track {\n  position: relative; display: flex;\n  justify-content: space-between; align-items: flex-start;\n}\n/* Background line (gray) */\n.vpc-bld__progress-track::before {\n  content: ''; position: absolute;\n  top: 42px; left: 12%; right: 12%;\n  height: 4px; background: #e0d6cc; border-radius: 2px; z-index: 0;\n}\n/* Active fill line */\n.vpc-bld__progress-fill {\n  position: absolute; top: 42px; left: 12%;\n  height: 4px; background: #34150C; border-radius: 2px;\n  z-index: 1; transition: width 0.4s ease; width: 0%;\n}\n\n.vpc-bld__step {\n  position: relative; z-index: 2; text-align: center;\n  flex: 1; cursor: pointer;\n}\n.vpc-bld__step-label {\n  display: block; font-size: 14px; font-weight: 700;\n  color: #999; margin-bottom: 10px; transition: color 0.3s;\n}\n.vpc-bld__step.is-active .vpc-bld__step-label,\n.vpc-bld__step.is-reached .vpc-bld__step-label { color: #34150C; }\n\n.vpc-bld__step-dot {\n  display: inline-flex; align-items: center; justify-content: center;\n  width: 22px; height: 22px; border-radius: 50%;\n  border: 3px solid #d0c4b8; background: #fff;\n  transition: all 0.3s ease; position: relative;\n}\n.vpc-bld__step.is-reached .vpc-bld__step-dot {\n  border-color: #34150C;\n}\n.vpc-bld__step.is-active .vpc-bld__step-dot {\n  border-color: #34150C; background: #34150C;\n  box-shadow: 0 0 0 4px rgba(52,21,12,0.15);\n}\n.vpc-bld__step.is-reached .vpc-bld__step-dot::after {\n  content: ''; width: 8px; height: 8px;\n  border-radius: 50%; background: #34150C;\n}\n.vpc-bld__step.is-active .vpc-bld__step-dot::after {\n  background: #fff;\n}\n\n.vpc-bld__step-price {\n  display: block; font-size: 12px; font-weight: 600;\n  color: #aaa; margin-top: 10px; transition: color 0.3s;\n}\n.vpc-bld__step.is-active .vpc-bld__step-price,\n.vpc-bld__step.is-reached .vpc-bld__step-price { color: #34150C; font-weight: 700; }\n\n.vpc-bld__step-best {\n  position: absolute; top: -14px; right: -6px;\n  background: #c62828; color: #fff;\n  font-size: 8px; font-weight: 800; padding: 3px 8px;\n  border-radius: 4px; text-transform: uppercase;\n  letter-spacing: 0.04em; transform: rotate(3deg);\n  box-shadow: 0 2px 6px rgba(198,40,40,0.25);\n}\n\n/* Savings bar */\n.vpc-bld__savings {\n  background: linear-gradient(135deg, #fdf8f4, #f9f0e6);\n  border: 1px solid #e8ddd2; border-radius: 10px;\n  padding: 0; margin-bottom: 0;\n  display: flex; align-items: center; justify-content: space-between;\n  transition: all 0.35s ease; opacity: 0;\n  max-height: 0; overflow: hidden; margin-bottom: 0;\n}\n.vpc-bld__savings.is-visible {\n  opacity: 1; max-height: 60px; margin-bottom: 8px; padding: 12px 16px;\n}\n.vpc-bld__savings-left {\n  display: flex; align-items: center; gap: 8px;\n}\n.vpc-bld__savings-icon {\n  width: 28px; height: 28px; background: #34150C; border-radius: 50%;\n  display: flex; align-items: center; justify-content: center; flex-shrink: 0;\n}\n.vpc-bld__savings-icon svg { width: 14px; height: 14px; }\n.vpc-bld__savings-text {\n  font-size: 13px; font-weight: 600; color: #34150C;\n}\n.vpc-bld__savings-amount {\n  font-size: 15px; font-weight: 800; color: #2e7d32;\n}\n\n/* Product list */\n.vpc-bld__list {\n  max-height: 440px; overflow-y: auto;\n  border: 1.5px solid #e8e0da; border-radius: 14px;\n  margin-bottom: 6px; scrollbar-width: thin; background: #fff;\n}\n.vpc-bld__list::-webkit-scrollbar { width: 4px; }\n.vpc-bld__list::-webkit-scrollbar-track { background: transparent; }\n.vpc-bld__list::-webkit-scrollbar-thumb { background: #d4c4b5; border-radius: 4px; }\n\n.vpc-bld__item {\n  display: flex; align-items: center;\n  padding: 14px 16px; border-bottom: 1px solid #f2ece6;\n  gap: 14px; transition: background 0.2s;\n}\n.vpc-bld__item:hover { background: #fefcfa; }\n.vpc-bld__item:last-child { border-bottom: none; }\n.vpc-bld__item.has-qty { background: #fdf8f4; }\n\n.vpc-bld__item-img {\n  width: 64px; height: 64px; border-radius: 10px;\n  object-fit: cover; flex-shrink: 0; background: #f9f3ec;\n  border: 1px solid #f0e8df;\n}\n.vpc-bld__item-info { flex: 1; min-width: 0; }\n.vpc-bld__item-name {\n  font-size: 14px; font-weight: 700; color: #34150C;\n  margin: 0 0 3px; white-space: nowrap;\n  overflow: hidden; text-overflow: ellipsis;\n}\n.vpc-bld__item-desc {\n  font-size: 12px; color: #999; margin: 0; line-height: 1.4;\n  display: -webkit-box; -webkit-line-clamp: 2;\n  -webkit-box-orient: vertical; overflow: hidden;\n}\n.vpc-bld__item-badge {\n  font-size: 9px; font-weight: 800; text-transform: uppercase;\n  padding: 2px 8px; border-radius: 20px; display: inline-block;\n  margin-bottom: 4px; letter-spacing: 0.03em;\n}\n.vpc-bld__item-badge--best { background: #fff3e0; color: #e65100; }\n.vpc-bld__item-badge--new { background: #e8f5e9; color: #2e7d32; }\n\n/* Add+ / Qty controls */\n.vpc-bld__item-action { flex-shrink: 0; }\n.vpc-bld__add-btn {\n  display: inline-flex; align-items: center; gap: 4px;\n  padding: 8px 18px; border-radius: 24px;\n  background: #34150C; color: #fff; border: none;\n  font-family: 'Poppins', sans-serif; font-size: 13px;\n  font-weight: 700; cursor: pointer;\n  transition: all 0.25s ease;\n  -webkit-tap-highlight-color: transparent;\n}\n.vpc-bld__add-btn:hover { background: #4a2518; transform: scale(1.03); }\n.vpc-bld__add-btn svg { width: 14px; height: 14px; }\n\n.vpc-bld__qty-wrap {\n  display: none; align-items: center; gap: 0;\n  background: #f5ede4; border-radius: 24px; padding: 4px;\n}\n.vpc-bld__item.has-qty .vpc-bld__add-btn { display: none; }\n.vpc-bld__item.has-qty .vpc-bld__qty-wrap { display: flex; }\n\n.vpc-bld__qbtn {\n  width: 30px; height: 30px; border-radius: 50%; border: none;\n  background: #34150C; color: #fff; font-size: 16px; font-weight: 600;\n  cursor: pointer; display: flex; align-items: center; justify-content: center;\n  transition: all 0.2s; -webkit-tap-highlight-color: transparent;\n}\n.vpc-bld__qbtn:hover { background: #4a2518; transform: scale(1.08); }\n.vpc-bld__qval {\n  width: 30px; text-align: center; font-size: 15px;\n  font-weight: 800; color: #34150C;\n}\n.vpc-bld__scroll-hint {\n  text-align: center; font-size: 12px; color: #bbb;\n  padding: 8px 0 18px; letter-spacing: 0.02em;\n}\n\n/* Items count pill */\n.vpc-bld__count {\n  display: flex; align-items: center; justify-content: center;\n  gap: 6px; margin-bottom: 8px; opacity: 0; transition: opacity 0.3s;\n}\n.vpc-bld__count.is-visible { opacity: 1; }\n.vpc-bld__count-pill {\n  background: #34150C; color: #fff; font-size: 12px; font-weight: 700;\n  padding: 5px 14px; border-radius: 20px;\n  display: inline-flex; align-items: center; gap: 6px;\n}\n.vpc-bld__count-pill svg { width: 14px; height: 14px; }\n\n/* ATC section */\n.vpc-bld__atc-wrap { margin-top: 18px; }\n.vpc-bld__atc-btn {\n  width: 100%; padding: 16px 20px;\n  background: #34150C; color: #fff;\n  font-family: 'Poppins', sans-serif; font-size: 15px;\n  font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em;\n  border: none; border-radius: 12px; cursor: pointer;\n  transition: all 0.3s ease;\n  display: flex; align-items: center; justify-content: center; gap: 12px;\n  box-shadow: 0 4px 16px rgba(52,21,12,0.2);\n  position: relative; overflow: hidden;\n}\n.vpc-bld__atc-btn::after {\n  content: ''; position: absolute; top: 0; left: -100%;\n  width: 100%; height: 100%;\n  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.1), transparent);\n  transition: left 0.5s;\n}\n.vpc-bld__atc-btn:not(:disabled):hover {\n  background: #4a2518; transform: translateY(-1px);\n  box-shadow: 0 6px 20px rgba(52,21,12,0.3);\n}\n.vpc-bld__atc-btn:not(:disabled):hover::after { left: 100%; }\n.vpc-bld__atc-btn:disabled { opacity: 0.4; cursor: not-allowed; box-shadow: none; }\n.vpc-bld__atc-original {\n  text-decoration: line-through; opacity: 0.6; font-weight: 400; font-size: 13px;\n}\n.vpc-bld__atc-final { font-size: 17px; font-weight: 800; }\n\n.vpc-bld__guarantee {\n  text-align: center; margin: 16px 0 0; font-size: 12px; color: #888;\n  display: flex; align-items: center; justify-content: center; gap: 8px; line-height: 1.5;\n}\n.vpc-bld__guarantee svg { width: 22px; height: 22px; flex-shrink: 0; opacity: 0.7; }\n.vpc-bld__guarantee strong { color: #34150C; }\n\n@media (max-width: 767px) {\n  .vpc-bld__tiers { padding: 14px 12px 10px; border-radius: 12px; }\n  .vpc-bld__step-label { font-size: 11px; margin-bottom: 8px; }\n  .vpc-bld__step-dot { width: 18px; height: 18px; border-width: 2.5px; }\n  .vpc-bld__step.is-reached .vpc-bld__step-dot::after { width: 6px; height: 6px; }\n  .vpc-bld__step.is-active .vpc-bld__step-dot { box-shadow: 0 0 0 3px rgba(52,21,12,0.12); }\n  .vpc-bld__step-price { font-size: 10px; margin-top: 8px; }\n  .vpc-bld__step-best { font-size: 7px; padding: 2px 5px; top: -12px; right: -4px; }\n  .vpc-bld__progress-track::before { top: 34px; }\n  .vpc-bld__progress-fill { top: 34px; }\n  .vpc-bld__header { text-align: center; }\n  .vpc-bld__label { font-size: 16px; }\n  .vpc-bld__item { padding: 10px 12px; gap: 10px; }\n  .vpc-bld__item-img { width: 52px; height: 52px; }\n  .vpc-bld__item-name { font-size: 13px; }\n  .vpc-bld__add-btn { padding: 7px 14px; font-size: 12px; }\n  .vpc-bld__qbtn { width: 28px; height: 28px; font-size: 14px; }\n  .vpc-bld__qval { width: 26px; font-size: 13px; }\n  .vpc-bld__qty-wrap { padding: 3px; }\n  .vpc-bld__atc-btn { padding: 14px 16px; font-size: 14px; border-radius: 10px; }\n  .vpc-bld__savings { padding: 0; }\n  .vpc-bld__savings.is-visible { padding: 10px 12px; }\n  .vpc-bld__savings-text { font-size: 12px; }\n  .vpc-bld__savings-amount { font-size: 14px; }\n}\n</style>\n\n<div class=\"vpc-bld\" id=\"vpcBundleBuilder\">\n  <div class=\"vpc-bld__header\">\n    <p class=\"vpc-bld__label\">Build Your Bundle</p>\n    <p class=\"vpc-bld__sublabel\">Mix & match your favorite scents. More you add, more you save!</p>\n  </div>\n\n  <div class=\"vpc-bld__tiers\" id=\"vpcBldTiers\">\n    <div class=\"vpc-bld__progress-track\">\n      <div class=\"vpc-bld__progress-fill\" id=\"vpcBldFill\"></div>\n\n      <div class=\"vpc-bld__step is-active\" data-min=\"1\" data-idx=\"0\">\n        <span class=\"vpc-bld__step-label\">1 candle</span>\n        <span class=\"vpc-bld__step-dot\"></span>\n        <span class=\"vpc-bld__step-price\" data-pct=\"0\">Full price</span>\n      </div>\n      <div class=\"vpc-bld__step\" data-min=\"2\" data-idx=\"1\">\n        <span class=\"vpc-bld__step-label\">2 candles</span>\n        <span class=\"vpc-bld__step-dot\"></span>\n        <span class=\"vpc-bld__step-price\" data-pct=\"5\">5% off/ea</span>\n      </div>\n      <div class=\"vpc-bld__step\" data-min=\"3\" data-idx=\"2\">\n        <span class=\"vpc-bld__step-label\">3 candles</span>\n        <span class=\"vpc-bld__step-dot\"></span>\n        <span class=\"vpc-bld__step-price\" data-pct=\"10\">10% off/ea</span>\n      </div>\n      <div class=\"vpc-bld__step\" data-min=\"4\" data-idx=\"3\">\n        <span class=\"vpc-bld__step-best\">BEST DEAL</span>\n        <span class=\"vpc-bld__step-label\">4+ candles</span>\n        <span class=\"vpc-bld__step-dot\"></span>\n        <span class=\"vpc-bld__step-price\" data-pct=\"15\">15% off/ea</span>\n      </div>\n    </div>\n  </div>\n\n  <div class=\"vpc-bld__savings\" id=\"vpcBldSavings\">\n    <div class=\"vpc-bld__savings-left\">\n      <span class=\"vpc-bld__savings-icon\"><svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#fff\" stroke-width=\"2\"><path d=\"M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z\"/><line x1=\"7\" y1=\"7\" x2=\"7.01\" y2=\"7\"/></svg></span>\n      <span class=\"vpc-bld__savings-text\">You're saving</span>\n    </div>\n    <span class=\"vpc-bld__savings-amount\" id=\"vpcBldSavingsAmt\">$0.00</span>\n  </div>\n\n  <div class=\"vpc-bld__count\" id=\"vpcBldCount\">\n    <span class=\"vpc-bld__count-pill\">\n      <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#fff\" stroke-width=\"2\"><circle cx=\"9\" cy=\"21\" r=\"1\"/><circle cx=\"20\" cy=\"21\" r=\"1\"/><path d=\"M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6\"/></svg>\n      <span id=\"vpcBldCountNum\">0 items</span>\n    </span>\n  </div>\n\n  <div class=\"vpc-bld__list\" id=\"vpcBldList\">\n    {%- for p in collections['19oz'].products -%}\n      {%- assign v = p.selected_or_first_available_variant -%}\n      <div class=\"vpc-bld__item\" data-vid=\"{{ v.id }}\" data-price=\"{{ v.price }}\">\n        <img class=\"vpc-bld__item-img\" src=\"{{ p.featured_image | image_url: width: 140 }}\" alt=\"{{ p.title | escape }}\" loading=\"lazy\">\n        <div class=\"vpc-bld__item-info\">\n          {%- if forloop.index <= 3 -%}<span class=\"vpc-bld__item-badge vpc-bld__item-badge--best\">Best Seller</span>{%- endif -%}\n          <p class=\"vpc-bld__item-name\">{{ p.title }}</p>\n          <p class=\"vpc-bld__item-desc\">{{ p.description | strip_html | truncate: 70 }}</p>\n        </div>\n        <div class=\"vpc-bld__item-action\">\n          <button class=\"vpc-bld__add-btn\" type=\"button\">Add <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\"><line x1=\"12\" y1=\"5\" x2=\"12\" y2=\"19\"/><line x1=\"5\" y1=\"12\" x2=\"19\" y2=\"12\"/></svg></button>\n          <div class=\"vpc-bld__qty-wrap\">\n            <button class=\"vpc-bld__qbtn vpc-bld__qminus\" type=\"button\">&minus;</button>\n            <span class=\"vpc-bld__qval\">0</span>\n            <button class=\"vpc-bld__qbtn vpc-bld__qplus\" type=\"button\">+</button>\n          </div>\n        </div>\n      </div>\n    {%- endfor -%}\n  </div>\n  \n\n  <div class=\"vpc-bld__atc-wrap\">\n    <button class=\"vpc-bld__atc-btn\" id=\"vpcBldAtc\" type=\"button\" disabled>\n      Select at least 2 candles\n    </button>\n    <p class=\"vpc-bld__guarantee\">\n      <svg viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"#34150C\" stroke-width=\"1.5\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/><path d=\"M9 12l2 2 4-4\"/></svg>\n      <span><strong>Try it risk-free for 30 days.</strong> If you're not totally in love, we will refund you 100%.</span>\n    </p>\n  </div>\n</div>\n\n<script>\n(function(){\n  var bb = document.getElementById('vpcBundleBuilder');\n  if (!bb) return;\n  var items = bb.querySelectorAll('.vpc-bld__item');\n  var steps = bb.querySelectorAll('.vpc-bld__step');\n  var fillBar = document.getElementById('vpcBldFill');\n  var atcBtn = document.getElementById('vpcBldAtc');\n  var savingsBar = document.getElementById('vpcBldSavings');\n  var savingsAmt = document.getElementById('vpcBldSavingsAmt');\n  var countEl = document.getElementById('vpcBldCount');\n  var countNum = document.getElementById('vpcBldCountNum');\n\n  function fmt(cents) { return '$' + (cents/100).toFixed(2); }\n\n  function getDiscount(total) {\n    if (total >= 4) return 15;\n    if (total >= 3) return 10;\n    if (total >= 2) return 5;\n    return 0;\n  }\n\n  function getActiveIdx(total) {\n    if (total >= 4) return 3;\n    if (total >= 3) return 2;\n    if (total >= 2) return 1;\n    return 0;\n  }\n\n  function update() {\n    var totalQty = 0, totalPrice = 0, cart = [];\n    items.forEach(function(item) {\n      var q = parseInt(item.querySelector('.vpc-bld__qval').textContent) || 0;\n      var p = parseInt(item.dataset.price) || 0;\n      if (q > 0) {\n        totalQty += q; totalPrice += p * q;\n        cart.push({ id: parseInt(item.dataset.vid), quantity: q });\n        item.classList.add('has-qty');\n      } else { item.classList.remove('has-qty'); }\n    });\n\n    var disc = getDiscount(totalQty);\n    var saved = Math.round(totalPrice * disc / 100);\n    var final_price = totalPrice - saved;\n    var activeIdx = getActiveIdx(totalQty);\n\n    /* Progress bar fill: 0%=first dot, 33.33%=2nd, 66.66%=3rd, 100%=4th */\n    var fillPcts = [0, 33.33, 66.66, 100];\n    var fillW = fillPcts[activeIdx];\n    /* Scale to the track width (left:12% to right:12% = 76% of container) */\n    fillBar.style.width = 'calc(' + (fillW * 0.76) + '%)';\n\n    /* Steps: reached = idx <= activeIdx, active = idx === activeIdx */\n    steps.forEach(function(s) {\n      var idx = parseInt(s.dataset.idx);\n      s.classList.toggle('is-reached', idx <= activeIdx);\n      s.classList.toggle('is-active', idx === activeIdx);\n    });\n\n    /* Savings bar */\n    if (saved > 0) {\n      savingsBar.classList.add('is-visible');\n      savingsAmt.textContent = fmt(saved);\n    } else { savingsBar.classList.remove('is-visible'); }\n\n    /* Count pill */\n    if (totalQty > 0) {\n      countEl.classList.add('is-visible');\n      countNum.textContent = totalQty + (totalQty === 1 ? ' item' : ' items');\n    } else { countEl.classList.remove('is-visible'); }\n\n    /* ATC button */\n    if (totalQty >= 2) {\n      atcBtn.disabled = false;\n      atcBtn.innerHTML = 'Add to Cart &nbsp;<span class=\"vpc-bld__atc-original\">' + fmt(totalPrice) + '</span> <span class=\"vpc-bld__atc-final\">' + fmt(final_price) + '</span>';\n    } else if (totalQty === 1) {\n      atcBtn.disabled = false;\n      atcBtn.innerHTML = 'Add to Cart &nbsp;' + fmt(totalPrice);\n    } else {\n      atcBtn.disabled = true;\n      atcBtn.textContent = 'Select at least 2 candles';\n    }\n    atcBtn.dataset.cart = JSON.stringify(cart);\n  }\n\n  items.forEach(function(item) {\n    var val = item.querySelector('.vpc-bld__qval');\n    item.querySelector('.vpc-bld__add-btn').addEventListener('click', function() {\n      val.textContent = 1; update();\n    });\n    item.querySelector('.vpc-bld__qplus').addEventListener('click', function() {\n      val.textContent = parseInt(val.textContent) + 1; update();\n    });\n    item.querySelector('.vpc-bld__qminus').addEventListener('click', function() {\n      var v = parseInt(val.textContent);\n      if (v > 0) { val.textContent = v - 1; update(); }\n    });\n  });\n\n  atcBtn.addEventListener('click', function() {\n    if (this.disabled) return;\n    var cart = JSON.parse(this.dataset.cart || '[]');\n    if (!cart.length) return;\n    this.innerHTML = '<span style=\"display:inline-flex;align-items:center;gap:8px\"><svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" style=\"animation:vpc-spin 0.8s linear infinite\"><circle cx=\"12\" cy=\"12\" r=\"10\" stroke-dasharray=\"30 70\"/></svg> ADDING...</span>';\n    this.disabled = true;\n    fetch('/cart/add.js', {\n      method: 'POST',\n      headers: {'Content-Type':'application/json'},\n      body: JSON.stringify({ items: cart })\n    }).then(function(r){ return r.json(); })\n    .then(function(){\n      atcBtn.innerHTML = '<svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\"><path d=\"M20 6L9 17l-5-5\"/></svg> ADDED!';\n      setTimeout(function(){ window.location.href='/cart'; }, 800);\n    }).catch(function(){\n      atcBtn.textContent = 'ERROR - TRY AGAIN';\n      atcBtn.disabled = false;\n    });\n  });\n\n  update();\n})();\n</script>\n<style>@keyframes vpc-spin{to{transform:rotate(360deg)}}</style>"
          }
        },
