    "custom_liquid_bgQAeG": {
      "type": "custom-liquid",
      "name": "Custom Liquid",
      "settings": {
        "custom_liquid": "<style>\n.vpc-wc3 {\n  font-family: 'Poppins', sans-serif;\n  background: #FAE9D4;\n  padding: 60px 20px;\n}\n.vpc-wc3__inner {\n  max-width: 960px;\n  margin: 0 auto;\n}\n.vpc-wc3__heading {\n  text-align: center;\n  font-size: 32px;\n  font-weight: 800;\n  color: #34150C;\n  margin: 0 0 10px;\n  letter-spacing: -0.02em;\n}\n.vpc-wc3__subtext {\n  text-align: center;\n  font-size: 14px;\n  color: #8b6f5e;\n  margin: 0 0 44px;\n  font-weight: 400;\n}\n.vpc-wc3__grid {\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  gap: 24px;\n}\n.vpc-wc3__card {\n  border-radius: 16px;\n  padding: 36px 28px;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  text-align: center;\n  position: relative;\n  overflow: hidden;\n  box-shadow: 0 4px 24px rgba(52,21,12,0.06);\n}\n.vpc-wc3__card--us {\n  background: rgba(255,255,255,0.7);\n  border: 2px solid rgba(52,21,12,0.1);\n}\n.vpc-wc3__card--them {\n  background: rgba(52,21,12,0.04);\n  border: 2px solid rgba(178,60,62,0.15);\n}\n.vpc-wc3__label {\n  font-size: 16px;\n  font-weight: 700;\n  margin: 0 0 22px;\n  letter-spacing: 0.02em;\n}\n.vpc-wc3__card--us .vpc-wc3__label { color: #2e7d32; }\n.vpc-wc3__card--them .vpc-wc3__label { color: #B23C3E; }\n.vpc-wc3__image {\n  width: 110px;\n  height: 110px;\n  border-radius: 50%;\n  object-fit: cover;\n  margin-bottom: 26px;\n  border: 3px solid rgba(52,21,12,0.1);\n  box-shadow: 0 6px 20px rgba(52,21,12,0.12);\n}\n.vpc-wc3__hazard {\n  width: 90px;\n  height: 90px;\n  object-fit: contain;\n  margin-bottom: 26px;\n  filter: drop-shadow(0 4px 12px rgba(178,60,62,0.15));\n}\n.vpc-wc3__list {\n  list-style: none;\n  padding: 0;\n  margin: 0;\n  width: 100%;\n  display: flex;\n  flex-direction: column;\n  gap: 10px;\n}\n.vpc-wc3__item {\n  display: flex;\n  align-items: center;\n  gap: 12px;\n  padding: 13px 16px;\n  border-radius: 10px;\n  font-size: 15px;\n  font-weight: 600;\n  color: #34150C;\n  text-align: left;\n}\n.vpc-wc3__card--us .vpc-wc3__item {\n  background: rgba(46,125,50,0.05);\n  border-left: 3px solid #2e7d32;\n}\n.vpc-wc3__card--them .vpc-wc3__item {\n  background: rgba(178,60,62,0.05);\n  border-left: 3px solid #B23C3E;\n}\n.vpc-wc3__icon-img {\n  width: 22px;\n  height: 22px;\n  object-fit: contain;\n  flex-shrink: 0;\n  opacity: 0.85;\n}\n.vpc-wc3__card--us .vpc-wc3__icon-img {\n  filter: brightness(0) saturate(100%) invert(30%) sepia(60%) saturate(600%) hue-rotate(85deg) brightness(95%);\n}\n.vpc-wc3__card--them .vpc-wc3__icon-img {\n  filter: brightness(0) saturate(100%) invert(25%) sepia(80%) saturate(800%) hue-rotate(340deg) brightness(85%);\n}\n@media (max-width: 767px) {\n  .vpc-wc3 { padding: 40px 12px; }\n  .vpc-wc3__heading { font-size: 24px; }\n  .vpc-wc3__subtext { margin-bottom: 28px; }\n  .vpc-wc3__grid { grid-template-columns: 1fr; gap: 16px; }\n  .vpc-wc3__card { padding: 28px 20px; }\n  .vpc-wc3__image { width: 90px; height: 90px; margin-bottom: 20px; }\n  .vpc-wc3__hazard { width: 72px; height: 72px; margin-bottom: 20px; }\n  .vpc-wc3__item { padding: 11px 14px; font-size: 14px; gap: 10px;\n    animation: vpc-wc3-pulse 2.5s ease-in-out infinite alternate;\n  }\n  .vpc-wc3__card--us .vpc-wc3__item {\n    animation-name: vpc-wc3-pulse-us;\n  }\n  .vpc-wc3__card--them .vpc-wc3__item {\n    animation-name: vpc-wc3-pulse-them;\n  }\n  @keyframes vpc-wc3-pulse-us {\n    0% { box-shadow: 0 0 0 rgba(46,125,50,0); transform: translateX(0); }\n    100% { box-shadow: 0 2px 14px rgba(46,125,50,0.2); transform: translateX(3px); }\n  }\n  @keyframes vpc-wc3-pulse-them {\n    0% { box-shadow: 0 0 0 rgba(178,60,62,0); transform: translateX(0); }\n    100% { box-shadow: 0 2px 14px rgba(178,60,62,0.2); transform: translateX(3px); }\n  }\n}\n</style>\n\n<section class=\"vpc-wc3\">\n  <div class=\"vpc-wc3__inner\">\n    <h2 class=\"vpc-wc3__heading\">Why Choose Vibes Pearl Candles?</h2>\n    <p class=\"vpc-wc3__subtext\">Clean ingredients, designed to last, and safe for your home</p>\n\n    <div class=\"vpc-wc3__grid\">\n      <!-- This is us -->\n      <div class=\"vpc-wc3__card vpc-wc3__card--us\">\n        <p class=\"vpc-wc3__label\">This is us</p>\n        <img class=\"vpc-wc3__image\" src=\"https://cdn.shopify.com/s/files/1/0920/7591/7591/files/Copy_of_vb28_e1a93f2c-f6ab-4bd8-b9c4-87b8c0774bfb.jpg?v=1755786897\" alt=\"Vibes Pearl Candle\">\n        <ul class=\"vpc-wc3__list\">\n          <li class=\"vpc-wc3__item\">\n            <img class=\"vpc-wc3__icon-img\" src=\"https://cdn.shopify.com/s/files/1/0920/7591/7591/files/chemical-free.png?v=1755110976\" alt=\"\">\n            Non Toxic\n          </li>\n          <li class=\"vpc-wc3__item\">\n            <img class=\"vpc-wc3__icon-img\" src=\"https://cdn.shopify.com/s/files/1/0920/7591/7591/files/fire_1.png?v=1755110977\" alt=\"\">\n            Even Burning\n          </li>\n          <li class=\"vpc-wc3__item\">\n            <img class=\"vpc-wc3__icon-img\" src=\"https://cdn.shopify.com/s/files/1/0920/7591/7591/files/animal_1.png?v=1755110977\" alt=\"\">\n            Pet Friendly\n          </li>\n          <li class=\"vpc-wc3__item\">\n            <img class=\"vpc-wc3__icon-img\" src=\"https://cdn.shopify.com/s/files/1/0920/7591/7591/files/lotus.png?v=1755110977\" alt=\"\">\n            Soothing\n          </li>\n        </ul>\n      </div>\n\n      <!-- This is not us -->\n      <div class=\"vpc-wc3__card vpc-wc3__card--them\">\n        <p class=\"vpc-wc3__label\">This is not us</p>\n        <img class=\"vpc-wc3__hazard\" src=\"https://cdn.shopify.com/s/files/1/0920/7591/7591/files/warning.png?v=1755245335\" alt=\"Hazard Warning\">\n        <ul class=\"vpc-wc3__list\">\n          <li class=\"vpc-wc3__item\">\n            <img class=\"vpc-wc3__icon-img\" src=\"https://cdn.shopify.com/s/files/1/0920/7591/7591/files/hazard.png?v=1755110727\" alt=\"\">\n            Synthetic Toxins\n          </li>\n          <li class=\"vpc-wc3__item\">\n            <img class=\"vpc-wc3__icon-img\" src=\"https://cdn.shopify.com/s/files/1/0920/7591/7591/files/hazard.png?v=1755110727\" alt=\"\">\n            Short Lifespan\n          </li>\n          <li class=\"vpc-wc3__item\">\n            <img class=\"vpc-wc3__icon-img\" src=\"https://cdn.shopify.com/s/files/1/0920/7591/7591/files/hazard.png?v=1755110727\" alt=\"\">\n            Harmful for Pets\n          </li>\n          <li class=\"vpc-wc3__item\">\n            <img class=\"vpc-wc3__icon-img\" src=\"https://cdn.shopify.com/s/files/1/0920/7591/7591/files/hazard.png?v=1755110727\" alt=\"\">\n            Soot & Smoke\n          </li>\n        </ul>\n      </div>\n    </div>\n  </div>\n</section>",
