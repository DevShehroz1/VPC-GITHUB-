      "name": "Custom Liquid",
      "settings": {
        "custom_liquid": "<div class=\"testimonial-section\">\n  <div class=\"testimonial-inner\">\n\n    <div class=\"video-cards\">\n\n      <div class=\"video-card\">\n        <video\n          src=\"https://cdn.shopify.com/videos/c/o/v/35b0754620a64f11bf193354a6f6253d.mp4\"\n          autoplay muted loop playsinline\n        ></video>\n        <div class=\"play-overlay\">\n          <svg viewBox=\"0 0 24 24\"><path d=\"M8 5v14l11-7z\" /></svg>\n        </div>\n      </div>\n\n      <div class=\"video-card\">\n        <video\n          src=\"https://cdn.shopify.com/videos/c/o/v/8e4a18586e574fdcbe4182ae405d4577.mp4\"\n          autoplay muted loop playsinline\n        ></video>\n        <div class=\"play-overlay\">\n          <svg viewBox=\"0 0 24 24\"><path d=\"M8 5v14l11-7z\" /></svg>\n        </div>\n      </div>\n\n      <div class=\"video-card\">\n        <video\n          src=\"https://cdn.shopify.com/videos/c/o/v/5c1a7b0689ff436685f13c5e4100d85d.mp4\"\n          autoplay muted loop playsinline\n        ></video>\n        <div class=\"play-overlay\">\n          <svg viewBox=\"0 0 24 24\"><path d=\"M8 5v14l11-7z\" /></svg>\n        </div>\n      </div>\n\n      <div class=\"video-card\">\n        <video\n          src=\"https://cdn.shopify.com/videos/c/o/v/969801e9f4844129b197b1debedd6509.mp4\"\n          autoplay muted loop playsinline\n        ></video>\n        <div class=\"play-overlay\">\n          <svg viewBox=\"0 0 24 24\"><path d=\"M8 5v14l11-7z\" /></svg>\n        </div>\n      </div>\n\n      <div class=\"video-card\">\n        <video\n          src=\"https://cdn.shopify.com/videos/c/o/v/06e93b15c3984256b50854f243465d80.mp4\"\n          autoplay muted loop playsinline\n        ></video>\n        <div class=\"play-overlay\">\n          <svg viewBox=\"0 0 24 24\"><path d=\"M8 5v14l11-7z\" /></svg>\n        </div>\n      </div>\n\n      <div class=\"video-card\">\n        <video\n          src=\"https://cdn.shopify.com/videos/c/o/v/6bb01d6a4ba5483c9bd3643481e39cf5.mp4\"\n          autoplay muted loop playsinline\n        ></video>\n        <div class=\"play-overlay\">\n          <svg viewBox=\"0 0 24 24\"><path d=\"M8 5v14l11-7z\" /></svg>\n        </div>\n      </div>\n\n      <div class=\"video-card\">\n        <video\n          src=\"https://cdn.shopify.com/videos/c/o/v/5f48039f8c1942f3a7928d408add877b.mp4\"\n          autoplay muted loop playsinline\n        ></video>\n        <div class=\"play-overlay\">\n          <svg viewBox=\"0 0 24 24\"><path d=\"M8 5v14l11-7z\" /></svg>\n        </div>\n      </div>\n\n    </div>\n\n  </div>\n</div>\n\n<style>\n  .testimonial-section {\n    width: 100%;\n    padding: 20px 0;\n  }\n\n  .testimonial-inner {\n    width: 100%;\n    padding: 0 10px;\n    box-sizing: border-box;\n  }\n\n  .video-cards {\n    display: flex;\n    gap: 16px;\n    overflow-x: auto;\n    scroll-snap-type: x mandatory;\n    -webkit-overflow-scrolling: touch;\n    padding: 0 10px 15px;\n    scrollbar-width: none;\n  }\n\n  .video-cards::-webkit-scrollbar {\n    display: none;\n  }\n\n  .video-card {\n    background: #fff;\n    border: 2px solid #fff;\n    border-radius: 6px;\n    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.1);\n    flex: 0 0 auto;\n    width: 240px;\n    height: 430px;\n    overflow: hidden;\n    position: relative;\n    cursor: pointer;\n    scroll-snap-align: start;\n    transition: transform 0.3s ease;\n  }\n\n  .video-card:hover {\n    transform: scale(1.03);\n  }\n\n  .video-card video {\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n    border-radius: 6px;\n  }\n\n  .play-overlay {\n    position: absolute;\n    top: 50%;\n    left: 50%;\n    transform: translate(-50%, -50%);\n    width: 55px;\n    height: 55px;\n    background: rgba(255, 255, 255, 0.85);\n    border-radius: 50%;\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    opacity: 0;\n    transition: opacity 0.25s ease;\n    pointer-events: none;\n  }\n\n  .play-overlay svg {\n    width: 24px;\n    height: 24px;\n    fill: #6d00c2;\n  }\n\n  .video-card.paused .play-overlay {\n    opacity: 1;\n  }\n\n  /* --------- MOBILE UPDATE (1.5 VIEW + BIGGER HEIGHT) --------- */\n  @media (max-width: 768px) {\n    .video-card {\n      width: 65%;       /* Shows 1.5 cards */\n      height: 380px;    /* Increased height */\n    }\n  }\n\n  @media (max-width: 480px) {\n    .video-card {\n      width: 70%;       /* 1.5 cards on small screens */\n      height: 340px;    /* Increased height */\n    }\n  }\n\n  video::-webkit-media-controls {\n    display: none !important;\n  }\n</style>\n\n<script>\n  document.addEventListener(\"DOMContentLoaded\", () => {\n    const cards = document.querySelectorAll(\".video-card\");\n\n    cards.forEach((card) => {\n      const video = card.querySelector(\"video\");\n\n      video.play();\n\n      card.addEventListener(\"click\", () => {\n        if (video.paused) {\n          video.play();\n          card.classList.remove(\"paused\");\n        } else {\n          video.pause();\n          card.classList.add(\"paused\");\n        }\n      });\n    });\n  });\n</script>",
