        "custom_liquid": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Candle Info Section</title>\n  <!-- Poppins font -->\n  <link href=\"https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n  <style>\n    body {\n      margin: 0;\n      font-family: 'Poppins', sans-serif;\n    }\n\n\n    /* Mobile only - hide on desktop */\n    @media (min-width: 768px) {\n      .mobile-candle-features {\n        display: none !important;\n      }\n    }\n\n    .mobile-candle-features {\n      position: relative;\n      background: url('https://cdn.shopify.com/s/files/1/0920/7591/7591/files/Copy_of_vb2.webp?v=1752503627') no-repeat center center/cover;\n      padding: 60px 20px;\n      color: #fff;\n      text-align: center;\n      overflow: hidden;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      min-height: 350px;\n    }\n\n    /* Brown overlay */\n    .mobile-candle-features::before {\n      content: \"\";\n      position: absolute;\n      top: 0; left: 0; right: 0; bottom: 0;\n      background: rgba(60, 30, 10, 0.7);\n      z-index: 1;\n    }\n\n    .mobile-candle-features > * {\n      position: relative;\n      z-index: 2;\n    }\n\n    /* Mobile icons layout */\n    .mobile-feature-icons {\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      justify-content: center;\n      gap: 0;\n      width: 100%;\n    }\n\n    .mobile-feature-row {\n      display: flex;\n      justify-content: center;\n      align-items: center;\n      gap: 30px;\n      flex-wrap: nowrap;\n      width: 100%;\n    }\n\n    .mobile-feature-item {\n      text-align: center;\n      color: #fff;\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      justify-content: center;\n    }\n\n    .mobile-feature-item img {\n      width: 50px;\n      height: 50px;\n      margin-bottom: 8px;\n      filter: brightness(0) invert(1);\n    }\n\n    .mobile-feature-item p {\n      font-weight: 600;\n      margin: 0;\n      font-size: 12px;\n      line-height: 1.3;\n      text-align: center;\n    }\n\n  </style>\n</head>\n<body>\n  \n  <section class=\"mobile-candle-features\">\n    <!-- Mobile Feature Icons -->\n    <div class=\"mobile-feature-icons\">\n      <div class=\"mobile-feature-row\">\n        <div class=\"mobile-feature-item\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0920/7591/7591/files/free-shipping.png?v=1751615179\" alt=\"Free Shipping Icon\">\n          <p>Free shipping in US</p>\n        </div>\n        <div class=\"mobile-feature-item\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0920/7591/7591/files/leaves.png?v=1751615389\" alt=\"Plant Based Icon\">\n          <p>100% Plant Based wax</p>\n        </div>\n        <div class=\"mobile-feature-item\">\n          <img src=\"https://cdn.shopify.com/s/files/1/0920/7591/7591/files/fire.png?v=1751615179\" alt=\"Burn Time Icon\">\n          <p>Long Lasting Burn Time</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n\n</body>\n</html>",
