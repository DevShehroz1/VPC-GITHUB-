        "custom_liquid": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>Why Choose – Mobile</title>\n  <!-- Poppins Font -->\n  <link href=\"https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap\" rel=\"stylesheet\">\n  <style>\n    .why-choose-mobile {\n      font-family: 'Poppins', sans-serif; /* only poppins font */\n      background: #FAE9D4; /* brand bg */\n      padding: 32px 16px 24px;\n      display: block; /* mobile default */\n    }\n\n    .why-choose-mobile .container {\n      max-width: 520px;\n      margin: 0 auto;\n    }\n\n    .why-choose-header .section-title {\n      color: #34150C;\n      font-size: 26px;\n      font-weight: 800;\n      letter-spacing: -0.2px;\n      margin: 0 0 8px;\n      text-align: center;\n    }\n\n    .comparison-section {\n      margin-bottom: 28px;\n    }\n\n    .comparison-title {\n      color: #B23C3E;\n      font-size: 17px;\n      font-weight: 800;\n      text-align: center;\n      margin: 0 0 14px;\n    }\n\n    .comparison-card {\n      background: rgba(250, 233, 212, 0.58); /* #FAE9D594 */\n      border: none;\n      border-radius: 12px;\n      padding: 14px;\n      box-shadow: none;\n    }\n\n    .comparison-content {\n      display: flex;\n      align-items: center;   /* align image + text vertically */\n      gap: 16px;\n      min-height: 140px;     /* same min height for both */\n    }\n\n    .candle-image-container,\n    .hazard-image-container {\n      flex: 0 0 100px;       /* same reserved width for both images */\n      display: flex;\n      align-items: center;\n      justify-content: center;\n    }\n\n    .candle-image {\n      width: 84px;\n      height: auto;\n      max-height: 120px;\n      object-fit: contain;\n      border-radius: 360px;\n      background: transparent;\n    }\n\n    .hazard-image {\n      width: auto;\n      height: auto;\n      max-width: 84px;       /* match candle image width */\n      max-height: 120px;\n      object-fit: contain;\n    }\n\n    .benefits-list, .drawbacks-list {\n      flex: 1;\n      display: flex;\n      flex-direction: column;\n      justify-content: center; /* vertically center list */\n      gap: 8px;\n    }\n\n    .benefit-item,\n    .drawback-item {\n      display: flex;\n      align-items: center;\n      gap: 8px;\n      padding: 4px 0;\n    }\n\n    .benefit-item img,\n    .drawback-item img {\n      width: auto;\n      height: auto;\n      max-width: 24px;\n      max-height: 24px;\n      flex: 0 0 auto;\n      object-fit: contain;\n      image-rendering: -webkit-optimize-contrast;\n      image-rendering: crisp-edges;\n    }\n\n    .benefit-item span,\n    .drawback-item span {\n      color: #34231C;\n      font-size: 14px;\n      font-weight: 600;\n      line-height: 1.2;\n    }\n\n    /* hide on tablet/desktop */\n    @media (min-width: 768px) {\n      .why-choose-mobile { display: none !important; }\n    }\n  </style>\n</head>\n<body>\n  <!-- Why Choose – Mobile -->\n  <section class=\"why-choose-mobile\" aria-label=\"Why Choose Vibes Pearl Candles – Mobile\">\n    <div class=\"container\">\n      <div class=\"why-choose-header\">\n        <h2 class=\"section-title\">Why Choose Vibes Pearl Candles?</h2>\n      </div>\n\n      <!-- This is us -->\n      <div class=\"comparison-section\">\n        <h3 class=\"comparison-title\">This is us</h3>\n        <div class=\"comparison-card\">\n          <div class=\"comparison-content\">\n            <div class=\"candle-image-container\">\n              <img class=\"candle-image\" alt=\"Vibes Pearl Candle\"\n                   src=\"https://cdn.shopify.com/s/files/1/0920/7591/7591/files/Copy_of_vb28_e1a93f2c-f6ab-4bd8-b9c4-87b8c0774bfb.jpg?v=1755786897\" />\n            </div>\n            <div class=\"benefits-list\">\n              <div class=\"benefit-item\">\n                <img alt=\"Non Toxic\"\n                     src=\"https://cdn.shopify.com/s/files/1/0920/7591/7591/files/chemical-free.png?v=1755110976\" />\n                <span>Non Toxic</span>\n              </div>\n              <div class=\"benefit-item\">\n                <img alt=\"Even Burning\"\n                     src=\"https://cdn.shopify.com/s/files/1/0920/7591/7591/files/fire_1.png?v=1755110977\" />\n                <span>Even Burning</span>\n              </div>\n              <div class=\"benefit-item\">\n                <img alt=\"Pet Friendly\"\n                     src=\"https://cdn.shopify.com/s/files/1/0920/7591/7591/files/animal_1.png?v=1755110977\" />\n                <span>Pet Friendly</span>\n              </div>\n              <div class=\"benefit-item\">\n                <img alt=\"Soothing\"\n                     src=\"https://cdn.shopify.com/s/files/1/0920/7591/7591/files/lotus.png?v=1755110977\" />\n                <span>Soothing</span>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      <!-- This is not us -->\n      <div class=\"comparison-section\" style=\"margin-bottom:0;\">\n        <h3 class=\"comparison-title\">This is not us</h3>\n        <div class=\"comparison-card\">\n          <div class=\"comparison-content\">\n            <div class=\"hazard-image-container\">\n              <img class=\"hazard-image\" alt=\"Hazard Warning\"\n                   src=\"https://cdn.shopify.com/s/files/1/0920/7591/7591/files/warning.png?v=1755245335\" />\n            </div>\n            <div class=\"drawbacks-list\">\n              <div class=\"drawback-item\">\n                <img alt=\"Warning icon\" src=\"https://cdn.shopify.com/s/files/1/0920/7591/7591/files/hazard.png?v=1755110727\" />\n                <span>Synthetic Toxins</span>\n              </div>\n              <div class=\"drawback-item\">\n                <img alt=\"Warning icon\" src=\"https://cdn.shopify.com/s/files/1/0920/7591/7591/files/hazard.png?v=1755110727\" />\n                <span>Short lifespan</span>\n              </div>\n              <div class=\"drawback-item\">\n                <img alt=\"Warning icon\" src=\"https://cdn.shopify.com/s/files/1/0920/7591/7591/files/hazard.png?v=1755110727\" />\n                <span>Harmful for Pets</span>\n              </div>\n              <div class=\"drawback-item\">\n                <img alt=\"Warning icon\" src=\"https://cdn.shopify.com/s/files/1/0920/7591/7591/files/hazard.png?v=1755110727\" />\n                <span>Soot & Smoke</span>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n\n    </div>\n  </section>\n</body>\n</html>",
