      "settings": {
        "custom_liquid": "<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>Product Video Section</title>\n<style>\n  body {\n    margin: 0;\n    font-family: sans-serif;\n  }\n\n  /* === FULL WIDTH FIX === */\n  .video-slider-wrapper {\n    position: relative;\n    width: 100vw;               /* span full viewport width */\n    left: 50%;                  /* center trick */\n    right: 50%;\n    margin-left: -50vw;         /* cancel parent container margins */\n    margin-right: -50vw;\n    box-sizing: border-box;\n    background: #f7e6d2;\n    padding: 30px 15px;         /* mobile padding */\n  }\n\n  @media (min-width: 1024px) {\n    .video-slider-wrapper {\n      padding: 30px 60px;       /* desktop padding */\n    }\n  }\n\n  .section-heading {\n    text-align: center;\n    font-size: 24px;\n    font-weight: 600;\n    margin: 0 0 30px 0;\n    color: #333;\n  }\n\n  @media (min-width: 768px) {\n    .section-heading {\n      font-size: 28px;\n      margin-bottom: 40px;\n    }\n  }\n\n  @media (min-width: 1024px) {\n    .section-heading {\n      font-size: 32px;\n      margin-bottom: 50px;\n    }\n  }\n\n  /* === VIDEO SLIDER === */\n  .video-slider {\n    display: flex;\n    gap: 10px;\n    overflow-x: auto;\n    scroll-snap-type: x mandatory;\n    white-space: nowrap;\n    scrollbar-width: none;\n    padding-bottom: 10px;\n  }\n\n  .video-slider::-webkit-scrollbar {\n    display: none;\n  }\n\n  .video-container {\n    flex: 0 0 auto;\n    width: 200px;\n    height: 350px;\n    border: none;\n    overflow: hidden;\n    border-radius: 6px;\n    position: relative;\n    scroll-snap-align: start;\n    cursor: pointer;\n  }\n\n  @media (min-width: 1024px) {\n    .video-container {\n      width: 200px;\n      height: 350px;\n    }\n  }\n\n  @media (min-width: 1440px) {\n    .video-container {\n      width: 250px;\n      height: 450px;\n    }\n  }\n\n  video {\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n  }\n\n  @media (min-width: 768px) {\n    .video-slider {\n      justify-content: center;\n      gap: 20px;\n    }\n  }\n\n  @media (min-width: 1024px) {\n    .video-slider {\n      gap: 25px;\n    }\n  }\n\n  @media (min-width: 1440px) {\n    .video-slider {\n      gap: 30px;\n    }\n  }\n\n  /* === MODAL === */\n  .modal-overlay {\n    position: fixed;\n    top: 0;\n    left: 0;\n    right: 0;\n    bottom: 0;\n    background: rgba(0, 0, 0, 0.75);\n    display: none;\n    align-items: center;\n    justify-content: center;\n    z-index: 9999;\n    padding: 20px;\n  }\n\n  .modal-overlay.active {\n    display: flex;\n  }\n\n  .modal-content {\n    position: relative;\n    width: 90vw;\n    max-width: 900px;\n    height: 90vh;\n    max-height: 700px;\n    background: #000;\n    border-radius: 12px;\n    overflow: hidden;\n    box-shadow: 0 10px 30px rgba(0,0,0,0.6);\n  }\n\n  .modal-content video {\n    width: 100%;\n    height: 100%;\n    object-fit: contain;\n    background: #000;\n  }\n\n  .modal-close {\n    position: absolute;\n    top: 8px;\n    right: 8px;\n    width: 36px;\n    height: 36px;\n    border: none;\n    border-radius: 50%;\n    background: rgba(255,255,255,0.9);\n    color: #000;\n    font-size: 22px;\n    cursor: pointer;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    line-height: 1;\n  }\n</style>\n\n<div class=\"video-slider-wrapper\">\n  \n\n  <div class=\"video-slider\" id=\"videoSlider\">\n    <div class=\"video-container\">\n      <video src=\"https://cdn.shopify.com/videos/c/o/v/b62025c09ece4ee58e558f9cca084a5b.mov\" autoplay=\"\" muted=\"\" loop=\"\" preload=\"auto\" playsinline=\"\"></video>\n    </div>\n    <div class=\"video-container\">\n      <video src=\"https://cdn.shopify.com/videos/c/o/v/2e8b7510c8ae4741ac81cc69d8db5724.mov\" autoplay=\"\" muted=\"\" loop=\"\" preload=\"auto\" playsinline=\"\"></video>\n    </div>\n    <div class=\"video-container\">\n      <video src=\"https://cdn.shopify.com/videos/c/o/v/4e93b76d592e41fab01782cce8df84d5.mov\" autoplay=\"\" muted=\"\" loop=\"\" preload=\"auto\" playsinline=\"\"></video>\n    </div>\n    <div class=\"video-container\">\n      <video src=\"https://cdn.shopify.com/videos/c/o/v/ac04f7ff1e6047f9b5f9b1461da5bf9a.mov\" autoplay=\"\" muted=\"\" loop=\"\" preload=\"auto\" playsinline=\"\"></video>\n    </div>\n    <div class=\"video-container\">\n      <video src=\"https://cdn.shopify.com/videos/c/o/v/f6886639171e4506a2f7d16a947b8953.mp4\" autoplay=\"\" muted=\"\" loop=\"\" preload=\"auto\" playsinline=\"\"></video>\n    </div>\n  </div>\n</div>\n\n<!-- === MODAL === -->\n<div class=\"modal-overlay\" id=\"videoModal\" aria-hidden=\"true\" role=\"dialog\" aria-label=\"Video player\">\n  <div class=\"modal-content\" id=\"modalContent\">\n    <button class=\"modal-close\" id=\"modalClose\" aria-label=\"Close\">×</button>\n    <video id=\"modalVideo\" controls=\"\" playsinline=\"\"></video>\n  </div>\n</div>\n\n<script>\n  document.addEventListener('DOMContentLoaded', () => {\n    const slider = document.getElementById('videoSlider');\n    const containers = slider.querySelectorAll('.video-container');\n    const modal = document.getElementById('videoModal');\n    const modalVideo = document.getElementById('modalVideo');\n    const modalClose = document.getElementById('modalClose');\n\n    containers.forEach((container) => {\n      container.addEventListener('click', () => {\n        const video = container.querySelector('video');\n        if (!video) return;\n        const src = video.currentSrc || video.src;\n        if (!src) return;\n        modalVideo.src = src;\n        modalVideo.currentTime = 0;\n        modal.setAttribute('aria-hidden', 'false');\n        modal.classList.add('active');\n        modalVideo.play().catch(() => {});\n      });\n    });\n\n    const closeModal = () => {\n      modal.classList.remove('active');\n      modal.setAttribute('aria-hidden', 'true');\n      try { modalVideo.pause(); } catch {}\n      modalVideo.removeAttribute('src');\n      modalVideo.load();\n    };\n\n    modalClose.addEventListener('click', closeModal);\n    modal.addEventListener('click', (e) => {\n      if (e.target === modal) closeModal();\n    });\n    document.addEventListener('keydown', (e) => {\n      if (e.key === 'Escape' && modal.classList.contains('active')) {\n        closeModal();\n      }\n    });\n  });\n</script>",
