          "settings": {
            "custom_liquid": "<style>\n    body {\n      margin: 0;\n      padding: 0;\n    }\n  \n    .icon-wrapper,\n    .custom-icon-row {\n      margin: 0 !important;\n      padding: 0 !important;\n    }\n  \n    .custom-icon-row {\n      display: flex;\n      justify-content: space-between;\n      align-items: center;\n      width: 100%;\n      text-align: center;\n      flex-wrap: nowrap;\n      overflow-x: hidden; /* Hide horizontal scrollbar */\n      -webkit-overflow-scrolling: touch;\n      gap: 0;\n      scrollbar-width: none; /* Firefox */\n    }\n    .custom-icon-row::-webkit-scrollbar {\n      display: none; /* Chrome, Safari, Opera */\n    }\n  \n    .icon-block {\n      flex: 0 0 33.33%;\n      max-width: 33.33%;\n      padding: 0; /* Removed top and bottom padding */\n      margin: 0;\n      box-sizing: border-box;\n      min-width: 120px;\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n    }\n  \n    .icon-block img {\n      width: 48px;\n      height: auto;\n      margin-bottom: 6px;\n      margin-top: 0; /* Ensure no top margin */\n    }\n  \n    .icon-block p {\n      font-size: 13px;\n      font-weight: 500;\n      margin: 0;\n      color: #333;\n      line-height: 1.2;\n    }\n  \n    .icon-block p + p {\n      font-size: 13px;\n      font-weight: 400;\n      color: #555;\n      margin-top: 2px;\n    }\n  \n    @media (max-width: 768px) {\n      .icon-block {\n        min-width: 100px;\n      }\n  \n      .icon-block img {\n        width: 36px;\n      }\n  \n      .icon-block p,\n      .icon-block p + p {\n        font-size: 12px;\n      }\n    }\n  \n    @media (max-width: 480px) {\n      .icon-block {\n        min-width: 90px;\n      }\n  \n      .icon-block img {\n        width: 30px;\n      }\n  \n      .icon-block p,\n      .icon-block p + p {\n        font-size: 11px;\n      }\n    }\n  </style>\n  \n  <div class=\"icon-wrapper\">\n    <div class=\"custom-icon-row\">\n      <div class=\"icon-block\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0920/7591/7591/files/free-shipping.png?v=1751615179\" alt=\"Free Shipping Icon\">\n        <p>Free shipping in</p>\n        <p>US</p>\n      </div>\n      <div class=\"icon-block\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0920/7591/7591/files/leaves.png?v=1751615389\" alt=\"Hassle-free returns Icon\">\n        <p>100 % Plant Based </p>\n        <p>wax</p>\n      </div>\n      <div class=\"icon-block\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0920/7591/7591/files/fire.png?v=1751615179\" alt=\"Secure checkout Icon\">\n        <p>Long Lasting</p>\n        <p>Burn Time</p>\n      </div>\n    </div>\n  </div>"
