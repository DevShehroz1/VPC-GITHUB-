    "custom_liquid_WUpP7n": {
      "type": "custom-liquid",
      "name": "Custom Liquid",
      "settings": {
        "custom_liquid": "<div style=\"text-align:center; padding: 20px;\">\n  <h2 style=\"font-size: 28px; font-weight: bold; color: #3d1b00; margin-bottom: 30px;\">\n    What is included\n  </h2>\n\n  <div class=\"what-included-row\">\n\n    <!-- Candle -->\n    <div class=\"included-img\">\n      <div class=\"img-wrap\">\n        {% if product.metafields.custom.image %}\n          <img src=\"{{ product.metafields.custom.image | image_url: width: 600 }}\" alt=\"Candle\">\n        {% endif %}\n      </div>\n      <p>Candle</p>\n    </div>\n\n    <div class=\"included-plus\">+</div>\n\n    <!-- Wicks -->\n    <div class=\"included-img\">\n      <div class=\"img-wrap\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0920/7591/7591/files/3_1_163653f2-4245-4341-b516-9402f0889ce0.png?v=1754577023\" alt=\"Wicks\">\n      </div>\n      <p>Wicks</p>\n    </div>\n\n    <div class=\"included-plus\">+</div>\n\n    <!-- Essential Oil -->\n    <div class=\"included-img\">\n      <div class=\"img-wrap\">\n        {% if product.metafields.custom.essential_oil %}\n          <img src=\"{{ product.metafields.custom.essential_oil | image_url: width: 600 }}\" alt=\"Essential oil\">\n        {% endif %}\n      </div>\n      <p>Essential oil</p>\n    </div>\n\n    <div class=\"included-plus\">+</div>\n\n    <!-- Magnetic box -->\n    <div class=\"included-img\">\n      <div class=\"img-wrap\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0920/7591/7591/files/WhatsApp_Image_2026-01-16_at_1.19.54_AM.jpg?v=1768508572\" alt=\"Magnetic box\">\n      </div>\n      <p>Magnetic box</p>\n    </div>\n\n  </div>\n</div>\n\n<style>\n/* DESKTOP */\n.what-included-row {\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  gap: 12px;\n}\n\n.included-img {\n  max-width: 210px;\n  text-align: center;\n}\n\n.img-wrap {\n  width: 100%;\n  aspect-ratio: 1 / 1;\n  overflow: hidden;\n  border-radius: 6px;\n}\n\n.img-wrap img {\n  width: 100%;\n  height: 100%;\n  object-fit: cover;\n}\n\n.included-img p {\n  font-weight: 600;\n  color: #3d1b00;\n  margin-top: 8px;\n}\n\n.included-plus {\n  font-size: 22px;\n  color: #8b5e3c;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n\n/* MOBILE — 2 IN A ROW */\n@media (max-width: 768px) {\n  .what-included-row {\n    display: grid;\n    grid-template-columns: repeat(2, 1fr);\n    gap: 10px;\n    align-items: start;\n  }\n\n  .included-plus {\n    display: none;\n  }\n\n  .included-img {\n    max-width: none;\n  }\n\n  .included-img p {\n    font-size: 14px;\n  }\n}\n</style>",
