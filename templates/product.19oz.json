    "custom_liquid_cncC6p": {
      "type": "custom-liquid",
      "disabled": true,
      "name": "Custom Liquid",
      "settings": {
        "custom_liquid": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Candle Info Section</title>\n  <!-- Poppins font -->\n  <link href=\"https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap\" rel=\"stylesheet\">\n  <style>\n    body {\n      margin: 0;\n      font-family: 'Poppins', sans-serif;\n    }\n\n    /* Desktop only */\n    @media (max-width: 991px) {\n      .candle-info-section {\n        display: none !important;\n      }\n    }\n\n    .candle-info-section {\n      position: relative;\n      background: url('https://cdn.shopify.com/s/files/1/0920/7591/7591/files/Copy_of_vb2.webp?v=1752503627') no-repeat center center/cover;\n      padding: 120px 20px; /* Increased height */\n      color: #fff;\n      text-align: center;\n      overflow: hidden;\n    }\n\n    /* Brown overlay */\n    .candle-info-section::before {\n      content: \"\";\n      position: absolute;\n      top: 0; left: 0; right: 0; bottom: 0;\n      background: rgba(60, 30, 10, 0.7);\n      z-index: 1;\n    }\n\n    .candle-info-section > * {\n      position: relative;\n      z-index: 2;\n    }\n\n    .accordion-row {\n      display: flex;\n      justify-content: center;\n      flex-wrap: wrap;\n      gap: 15px;\n      margin-bottom: 80px; /* more space before icons */\n    }\n\n    .accordion-item {\n      border: 1px solid #fff;\n      border-radius: 6px;\n      padding: 12px 20px;\n      display: flex;\n      justify-content: space-between;\n      align-items: center;\n      cursor: pointer;\n      min-width: 220px;\n      background: rgba(255, 255, 255, 0.05);\n      transition: background 0.3s;\n      color: #fff;\n    }\n\n    .accordion-item:hover {\n      background: rgba(255, 255, 255, 0.15);\n    }\n\n    .accordion-item strong {\n      font-weight: 600;\n      font-size: 15px;\n    }\n\n    .accordion-item span {\n      font-size: 18px;\n      font-weight: bold;\n    }\n\n    /* Popup */\n    .popup-overlay {\n      display: none;\n      position: fixed;\n      top: 0; left: 0;\n      width: 100%; height: 100%;\n      background: rgba(0,0,0,0.8);\n      justify-content: center;\n      align-items: center;\n      z-index: 9999;\n    }\n\n    .popup-content {\n      background: #fff;\n      color: #000;\n      padding: 30px;\n      border-radius: 10px;\n      max-width: 600px;\n      text-align: left;\n      position: relative;\n      font-family: 'Poppins', sans-serif;\n    }\n\n    .popup-content h3 {\n      margin-top: 0;\n      margin-bottom: 15px;\n      font-weight: 600;\n    }\n\n    .popup-content p {\n      margin-bottom: 10px;\n      line-height: 1.6;\n    }\n\n    .popup-close {\n      position: absolute;\n      top: 12px;\n      right: 12px;\n      font-size: 20px;\n      cursor: pointer;\n      font-weight: bold;\n    }\n\n    /* Icons at bottom */\n    .icon-row {\n      display: flex;\n      justify-content: center;\n      gap: 100px;\n      flex-wrap: wrap;\n    }\n\n    .icon-box {\n      text-align: center;\n      color: #fff;\n      max-width: 200px;\n    }\n\n    .icon-box img {\n      max-width: 70px;\n      margin-bottom: 12px;\n    }\n\n    .icon-box p {\n      font-weight: 600;\n      margin: 0;\n    }\n  </style>\n</head>\n<body>\n  \n  <section class=\"candle-info-section\">\n    <div class=\"accordion-row\">\n      <div class=\"accordion-item\" data-popup=\"included\"><strong>Included</strong><span>+</span></div>\n      <div class=\"accordion-item\" data-popup=\"ingredients\"><strong>Ingredients</strong><span>+</span></div>\n      <div class=\"accordion-item\" data-popup=\"burntime\"><strong>Burn Time</strong><span>+</span></div>\n      <div class=\"accordion-item\" data-popup=\"howtouse\"><strong>How to Use</strong><span>+</span></div>\n    </div>\n\n    <!-- Popup -->\n    <div class=\"popup-overlay\" id=\"popup\">\n      <div class=\"popup-content\">\n        <span class=\"popup-close\">&times;</span>\n        <div id=\"popup-text\"></div>\n      </div>\n    </div>\n\n    <!-- Bottom Icons -->\n    <div class=\"icon-row\">\n      <div class=\"icon-box\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0920/7591/7591/files/image_5.png?v=1756754744\" alt=\"eco\">\n        <p>Refillable & Eco-friendly</p>\n      </div>\n      <div class=\"icon-box\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0920/7591/7591/files/image_4.png?v=1756754742\" alt=\"clean burning\">\n        <p>Safe and Clean Burning</p>\n      </div>\n      <div class=\"icon-box\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0920/7591/7591/files/image_3.png?v=1756754742\" alt=\"pet friendly\">\n        <p>Pet Friendly</p>\n      </div>\n    </div>\n  </section>\n\n  <script>\n    const popupOverlay = document.getElementById(\"popup\");\n    const popupText = document.getElementById(\"popup-text\");\n    const closeBtn = document.querySelector(\".popup-close\");\n\n    const popupData = {\n      included: `\n        <h3>What's Included</h3>\n        <p><strong>Premium Wax Pearls (19 oz)</strong></p>\n        <p><strong>Cotton Wicks</strong> - Specially designed for a clean, consistent flame.</p>\n        <p><strong>Instruction Manual</strong> - Simple steps to make the most of your pearled candle every time.</p>\n      `,\n      ingredients: `\n        <h3>Ingredients</h3>\n        <p><strong>100% Plant-Based Wax</strong> - Clean-burning, non-toxic, and free from paraffin.</p>\n        <p><strong>Premium Fragrance Oils</strong> - Thoughtfully curated for a balanced, long-lasting scent.</p>\n        <p><strong>Phthalate-Free Fragrances</strong> - Luxurious, non-toxic scents crafted to enhance your mood.</p>\n      `,\n      burntime: `\n        <h3>Burn Time</h3>\n        <p><strong>19 oz Candle:</strong> Our 19 oz candles are provided with 15 wicks.</p>\n        <p>Each Wick burns for 12 hrs.</p>\n      `,\n      howtouse: `\n        <h3>How to Use</h3>\n        <p><strong>Trim the Wick</strong> - Before lighting, trim the wick to 1/4 inch for a clean, even burn.</p>\n        <p><strong>Burn Safely</strong> - Keep the candle on a flat, heat-resistant surface, and never leave it unattended.</p>\n      `\n    };\n\n    document.querySelectorAll(\".accordion-item\").forEach(item => {\n      item.addEventListener(\"click\", () => {\n        const type = item.getAttribute(\"data-popup\");\n        popupText.innerHTML = popupData[type];\n        popupOverlay.style.display = \"flex\";\n      });\n    });\n\n    closeBtn.addEventListener(\"click\", () => {\n      popupOverlay.style.display = \"none\";\n    });\n\n    popupOverlay.addEventListener(\"click\", (e) => {\n      if (e.target === popupOverlay) {\n        popupOverlay.style.display = \"none\";\n      }\n    });\n  </script>\n\n</body>\n</html>",
