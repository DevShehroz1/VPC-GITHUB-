    "custom_liquid_LLn4zK": {
      "type": "custom-liquid",
      "name": "Custom Liquid",
      "settings": {
        "custom_liquid": "<style>\n.vpc-why-choose {\n  font-family: 'Poppins', sans-serif;\n  background: #FAE9D4;\n  padding: 50px 15px;\n}\n.vpc-why-choose__inner {\n  max-width: 900px;\n  margin: 0 auto;\n}\n.vpc-why-choose__heading {\n  text-align: center;\n  font-size: 28px;\n  font-weight: 700;\n  color: #34150C;\n  margin: 0 0 40px;\n}\n.vpc-why-choose__grid {\n  display: grid;\n  grid-template-columns: 1fr 1fr;\n  gap: 24px;\n}\n/* Card base */\n.vpc-wc-card {\n  border-radius: 12px;\n  padding: 28px 24px;\n  display: flex;\n  flex-direction: column;\n  align-items: center;\n  text-align: center;\n}\n/* This is us */\n.vpc-wc-card--us {\n  background: rgba(255,255,255,0.7);\n  border: 2px solid rgba(52,21,12,0.1);\n}\n/* This is not us */\n.vpc-wc-card--them {\n  background: rgba(52,21,12,0.04);\n  border: 2px solid rgba(178,60,62,0.15);\n}\n.vpc-wc-card__label {\n  font-size: 15px;\n  font-weight: 700;\n  margin: 0 0 20px;\n  letter-spacing: 0.02em;\n}\n.vpc-wc-card--us .vpc-wc-card__label { color: #2e7d32; }\n.vpc-wc-card--them .vpc-wc-card__label { color: #B23C3E; }\n\n.vpc-wc-card__image {\n  width: 100px;\n  height: 100px;\n  border-radius: 50%;\n  object-fit: cover;\n  margin-bottom: 20px;\n  border: 3px solid rgba(52,21,12,0.1);\n}\n.vpc-wc-card__hazard {\n  width: 80px;\n  height: 80px;\n  object-fit: contain;\n  margin-bottom: 20px;\n}\n\n.vpc-wc-list {\n  list-style: none;\n  padding: 0;\n  margin: 0;\n  width: 100%;\n  display: flex;\n  flex-direction: column;\n  gap: 10px;\n}\n.vpc-wc-list__item {\n  display: flex;\n  align-items: center;\n  gap: 10px;\n  padding: 10px 14px;\n  border-radius: 8px;\n  font-size: 14px;\n  font-weight: 600;\n  color: #34150C;\n}\n.vpc-wc-card--us .vpc-wc-list__item {\n  background: rgba(46,125,50,0.06);\n}\n.vpc-wc-card--them .vpc-wc-list__item {\n  background: rgba(178,60,62,0.06);\n}\n.vpc-wc-list__icon {\n  width: 22px;\n  height: 22px;\n  object-fit: contain;\n  flex-shrink: 0;\n}\n/* Checkmark for \"us\" items */\n.vpc-wc-check {\n  width: 22px;\n  height: 22px;\n  border-radius: 50%;\n  background: #2e7d32;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  flex-shrink: 0;\n}\n.vpc-wc-check svg { width: 12px; height: 12px; }\n/* X mark for \"not us\" items */\n.vpc-wc-cross {\n  width: 22px;\n  height: 22px;\n  border-radius: 50%;\n  background: #B23C3E;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  flex-shrink: 0;\n}\n.vpc-wc-cross svg { width: 10px; height: 10px; }\n\n@media (max-width: 767px) {\n  .vpc-why-choose { padding: 40px 10px; }\n  .vpc-why-choose__heading { font-size: 22px; margin-bottom: 24px; }\n  .vpc-why-choose__grid { grid-template-columns: 1fr; gap: 16px; }\n  .vpc-wc-card { padding: 24px 18px; }\n  .vpc-wc-list__item { padding: 8px 12px; font-size: 13px; }\n}\n</style>\n\n<section class=\"vpc-why-choose\">\n  <div class=\"vpc-why-choose__inner\">\n    <h2 class=\"vpc-why-choose__heading\">Why Choose Vibes Pearl Candles?</h2>\n\n    <div class=\"vpc-why-choose__grid\">\n      <!-- This is us -->\n      <div class=\"vpc-wc-card vpc-wc-card--us\">\n        <p class=\"vpc-wc-card__label\">This is us</p>\n        <img class=\"vpc-wc-card__image\" src=\"https://cdn.shopify.com/s/files/1/0920/7591/7591/files/Copy_of_vb28_e1a93f2c-f6ab-4bd8-b9c4-87b8c0774bfb.jpg?v=1755786897\" alt=\"Vibes Pearl Candle\">\n        <ul class=\"vpc-wc-list\">\n          <li class=\"vpc-wc-list__item\">\n            <span class=\"vpc-wc-check\"><svg viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M2 6.5L4.5 9L10 3\" stroke=\"#fff\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></span>\n            Non Toxic\n          </li>\n          <li class=\"vpc-wc-list__item\">\n            <span class=\"vpc-wc-check\"><svg viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M2 6.5L4.5 9L10 3\" stroke=\"#fff\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></span>\n            Even Burning\n          </li>\n          <li class=\"vpc-wc-list__item\">\n            <span class=\"vpc-wc-check\"><svg viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M2 6.5L4.5 9L10 3\" stroke=\"#fff\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></span>\n            Pet Friendly\n          </li>\n          <li class=\"vpc-wc-list__item\">\n            <span class=\"vpc-wc-check\"><svg viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M2 6.5L4.5 9L10 3\" stroke=\"#fff\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></span>\n            Soothing\n          </li>\n        </ul>\n      </div>\n\n      <!-- This is not us -->\n      <div class=\"vpc-wc-card vpc-wc-card--them\">\n        <p class=\"vpc-wc-card__label\">This is not us</p>\n        <img class=\"vpc-wc-card__hazard\" src=\"https://cdn.shopify.com/s/files/1/0920/7591/7591/files/warning.png?v=1755245335\" alt=\"Hazard Warning\">\n        <ul class=\"vpc-wc-list\">\n          <li class=\"vpc-wc-list__item\">\n            <span class=\"vpc-wc-cross\"><svg viewBox=\"0 0 10 10\" fill=\"none\"><path d=\"M2 2L8 8M8 2L2 8\" stroke=\"#fff\" stroke-width=\"2\" stroke-linecap=\"round\"/></svg></span>\n            Synthetic Toxins\n          </li>\n          <li class=\"vpc-wc-list__item\">\n            <span class=\"vpc-wc-cross\"><svg viewBox=\"0 0 10 10\" fill=\"none\"><path d=\"M2 2L8 8M8 2L2 8\" stroke=\"#fff\" stroke-width=\"2\" stroke-linecap=\"round\"/></svg></span>\n            Short Lifespan\n          </li>\n          <li class=\"vpc-wc-list__item\">\n            <span class=\"vpc-wc-cross\"><svg viewBox=\"0 0 10 10\" fill=\"none\"><path d=\"M2 2L8 8M8 2L2 8\" stroke=\"#fff\" stroke-width=\"2\" stroke-linecap=\"round\"/></svg></span>\n            Harmful for Pets\n          </li>\n          <li class=\"vpc-wc-list__item\">\n            <span class=\"vpc-wc-cross\"><svg viewBox=\"0 0 10 10\" fill=\"none\"><path d=\"M2 2L8 8M8 2L2 8\" stroke=\"#fff\" stroke-width=\"2\" stroke-linecap=\"round\"/></svg></span>\n            Soot & Smoke\n          </li>\n        </ul>\n      </div>\n    </div>\n  </div>\n</section>",
