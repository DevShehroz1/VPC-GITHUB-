        "custom_liquid_rtGFgt": {
          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "<div class=\"mobile-badge-wrapper\">\n  <div class=\"mobile-badge-container\">\n    <img src=\"https://cdn.shopify.com/s/files/1/0920/7591/7591/files/image_2.png?v=1754767673\" alt=\"Shipping Icon\" class=\"mobile-badge-image\">\n    <span class=\"mobile-badge-text\"> Free Shipping</span>\n  </div>\n</div>\n\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;600&display=swap');\n\n  .mobile-badge-wrapper {\n    background-color: #faebd7; /* beige background */\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    padding: 20px 0;\n    font-family: 'Poppins', sans-serif;\n  }\n\n  .mobile-badge-container {\n    display: flex;\n    align-items: center;\n    gap: 8px;\n    background-color: #ffffff; /* white background */\n    border: 1.5px solid #e0c7b1;\n    border-radius: 8px; /* reduced radius */\n    padding: 8px 16px;\n    box-shadow: 0px 2px 5px rgba(0,0,0,0.08);\n    position: relative;\n  }\n\n  .mobile-badge-container::before,\n  .mobile-badge-container::after {\n    content: \"\";\n    flex: 1;\n    height: 1px;\n    background-color: #d8b99e;\n    position: absolute;\n    top: 50%;\n  }\n\n  .mobile-badge-container::before {\n    left: -50px;\n    width: 50px;\n  }\n\n  .mobile-badge-container::after {\n    right: -50px;\n    width: 50px;\n  }\n\n  .mobile-badge-image {\n    height: 30px; /* increased size */\n    width: auto;\n    display: block;\n  }\n\n  .mobile-badge-text {\n    font-weight: 600;\n    font-size: 14px;\n    color: #000; /* black text */\n  }\n\n  /* Hide on tablets & desktop, show only on mobile */\n  @media (min-width: 769px) {\n    .mobile-badge-wrapper {\n      display: none !important;\n    }\n  }\n</style>"
          }
        },
        "custom_liquid_desktop_accordion_tabs": {
          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "<style>\n/* ===== FORCE SHOPIFY PAY BUTTON VISIBLE ===== */\n.shopify-payment-button__more-options,\n.t4s-product-form__buttons .shopify-payment-button__more-options {\n  display: none !important;\n}\n.shopify-payment-button__button,\n.shopify-payment-button__button--branded,\n.shopify-payment-button__button--unbranded {\n  border-radius: 6px !important;\n}\n.t4s-product-form__buttons .shopify-payment-button,\n.shopify-payment-button {\n  display: block !important;\n  margin-top: 10px !important;\n}\n\n/* ===== DESKTOP: Hide mobile accordion, show desktop ===== */\n@media (min-width: 768px) {\n  .vpc-mobile-accordion { display: none !important; }\n  .vpc-mobile-sheet-overlay { display: none !important; }\n  .vpc-mobile-sheet { display: none !important; }\n}\n\n/* ===== MOBILE: Hide desktop accordion, show mobile ===== */\n@media (max-width: 767px) {\n  .vpc-desktop-accordion { display: none !important; }\n  .vpc-drawer-overlay { display: none !important; }\n  .vpc-drawer { display: none !important; }\n}\n\n/* ===== DESKTOP ACCORDION + DRAWER ===== */\n@media (min-width: 768px) {\n  .vpc-desktop-accordion {\n    width: 100%;\n    border-top: 1px solid #000;\n    margin-top: 8px;\n  }\n  .vpc-accordion-item {\n    border-bottom: 1px solid #000;\n  }\n  .vpc-accordion-header {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    padding: 16px 0;\n    cursor: pointer;\n    background: none !important;\n    border: none;\n    width: 100%;\n    text-align: left;\n    font-family: 'Poppins', sans-serif;\n    font-size: 14px;\n    font-weight: 700;\n    letter-spacing: 0.08em;\n    text-transform: none;\n    color: #1a1a1a !important;\n    transition: none;\n    outline: none;\n    -webkit-tap-highlight-color: transparent;\n  }\n  .vpc-accordion-header:hover,\n  .vpc-accordion-header:focus,\n  .vpc-accordion-header:active,\n  .vpc-accordion-header:focus-visible {\n    color: #1a1a1a !important;\n    background: none !important;\n    outline: none !important;\n    box-shadow: none !important;\n  }\n  .vpc-accordion-chevron {\n    width: 12px;\n    height: 12px;\n    flex-shrink: 0;\n    color: #1a1a1a;\n  }\n\n  /* Right side drawer */\n  .vpc-drawer-overlay {\n    position: fixed;\n    top: 0; left: 0;\n    width: 100%; height: 100%;\n    background: rgba(0, 0, 0, 0.5);\n    z-index: 99998;\n    opacity: 0;\n    visibility: hidden;\n    transition: opacity 0.3s ease, visibility 0.3s ease;\n  }\n  .vpc-drawer-overlay.is-visible {\n    opacity: 1;\n    visibility: visible;\n  }\n  .vpc-drawer {\n    position: fixed;\n    top: 0; right: 0;\n    width: 420px;\n    max-width: 90vw;\n    height: 100%;\n    background: #fae9d4;\n    z-index: 99999;\n    transform: translateX(100%);\n    transition: transform 0.35s cubic-bezier(0.25, 0.8, 0.25, 1);\n    box-shadow: -4px 0 20px rgba(0, 0, 0, 0.1);\n    display: flex;\n    flex-direction: column;\n  }\n  .vpc-drawer.is-open {\n    transform: translateX(0);\n  }\n  .vpc-drawer-header {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    padding: 20px 24px;\n    border-bottom: 1px solid #000;\n    flex-shrink: 0;\n  }\n  .vpc-drawer-title {\n    font-family: 'Poppins', sans-serif;\n    font-size: 15px;\n    font-weight: 700;\n    letter-spacing: 0.06em;\n    text-transform: uppercase;\n    color: #1a1a1a;\n    margin: 0;\n  }\n  .vpc-drawer-close {\n    background: none;\n    border: none;\n    cursor: pointer;\n    padding: 4px;\n    color: #1a1a1a;\n    line-height: 1;\n  }\n  .vpc-drawer-close:hover { color: #555; }\n  .vpc-drawer-close svg { width: 18px; height: 18px; }\n  .vpc-drawer-body {\n    padding: 24px;\n    overflow-y: auto;\n    flex: 1;\n    font-family: 'Poppins', sans-serif;\n    font-size: 14px;\n    line-height: 1.8;\n    color: #444;\n  }\n  .vpc-drawer-body p { margin: 0 0 12px 0; }\n  .vpc-drawer-body p:last-child { margin-bottom: 0; }\n  .vpc-drawer-body strong { color: #1a1a1a; }\n\n  /* Trust badges wrapper */\n  .vpc-trust-wrapper {\n    background: rgba(52, 21, 12, 0.06);\n    border-radius: 6px;\n    padding: 20px 16px;\n    margin-top: 16px;\n  }\n\n  /* Trust badges */\n  .vpc-desktop-trust-badges {\n    display: flex;\n    justify-content: space-between;\n    align-items: flex-start;\n    gap: 16px;\n    padding: 20px 16px;\n    margin-top: 4px;\n    }\n  .vpc-trust-badge {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    text-align: center;\n    flex: 1;\n    gap: 8px;\n  }\n  .vpc-trust-badge img {\n    width: 40px; height: 40px; object-fit: contain;\n    filter: brightness(0) saturate(100%) invert(8%) sepia(30%) saturate(3500%) hue-rotate(350deg) brightness(95%) contrast(100%);\n  }\n  .vpc-trust-badge span {\n    font-family: 'Poppins', sans-serif;\n    font-size: 11px;\n    font-weight: 600;\n    color: #34150C;\n    letter-spacing: 0.02em;\n    line-height: 1.3;\n  }\n}\n\n/* ===== MOBILE ACCORDION + BOTTOM SHEET ===== */\n@media (max-width: 767px) {\n  .vpc-mobile-accordion {\n    width: 100%;\n    border-top: 1px solid #000;\n    margin-top: 12px;\n  }\n  .vpc-mob-acc-item {\n    border-bottom: 1px solid #000;\n  }\n  .vpc-mob-acc-header {\n    display: flex;\n    justify-content: space-between;\n    align-items: center;\n    padding: 14px 0;\n    cursor: pointer;\n    background: none !important;\n    border: none;\n    width: 100%;\n    text-align: left;\n    font-family: 'Poppins', sans-serif;\n    font-size: 13px;\n    font-weight: 700;\n    letter-spacing: 0.08em;\n    text-transform: none;\n    color: #1a1a1a !important;\n    -webkit-tap-highlight-color: transparent;\n  }\n  .vpc-mob-acc-header:hover,\n  .vpc-mob-acc-header:focus,\n  .vpc-mob-acc-header:active {\n    color: #1a1a1a !important;\n    background: none !important;\n    outline: none !important;\n  }\n  .vpc-mob-chevron {\n    width: 12px; height: 12px;\n    flex-shrink: 0;\n    color: #1a1a1a;\n  }\n\n  /* Bottom sheet overlay */\n  .vpc-mobile-sheet-overlay {\n    position: fixed;\n    top: 0; left: 0;\n    width: 100%; height: 100%;\n    background: rgba(0, 0, 0, 0.5);\n    z-index: 99998;\n    opacity: 0;\n    visibility: hidden;\n    transition: opacity 0.3s ease, visibility 0.3s ease;\n  }\n  .vpc-mobile-sheet-overlay.is-visible {\n    opacity: 1;\n    visibility: visible;\n  }\n\n  /* Bottom sheet */\n  .vpc-mobile-sheet {\n    position: fixed;\n    bottom: 0; left: 0; right: 0;\n    background: #fae9d4;\n    z-index: 99999;\n    transform: translateY(100%);\n    transition: transform 0.35s cubic-bezier(0.25, 0.8, 0.25, 1);\n    border-radius: 16px 16px 0 0;\n    max-height: 85vh;\n    display: flex;\n    flex-direction: column;\n    box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.1);\n  }\n  .vpc-mobile-sheet.is-open {\n    transform: translateY(0);\n  }\n\n  /* Drag handle */\n  .vpc-sheet-handle {\n    width: 40px;\n    height: 4px;\n    background: #ccc;\n    border-radius: 2px;\n    margin: 10px auto 0;\n    flex-shrink: 0;\n  }\n\n  .vpc-sheet-header {\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    padding: 16px 20px;\n    border-bottom: 1px solid #e0e0e0;\n    flex-shrink: 0;\n    position: relative;\n  }\n  .vpc-sheet-title {\n    font-family: 'Poppins', sans-serif;\n    font-size: 14px;\n    font-weight: 700;\n    letter-spacing: 0.06em;\n    text-transform: uppercase;\n    color: #1a1a1a;\n    margin: 0;\n  }\n  .vpc-sheet-close {\n    position: absolute;\n    right: 20px;\n    top: 50%;\n    transform: translateY(-50%);\n    background: none;\n    border: none;\n    cursor: pointer;\n    padding: 4px;\n    color: #1a1a1a;\n    line-height: 1;\n  }\n  .vpc-sheet-close svg { width: 16px; height: 16px; }\n\n  .vpc-sheet-body {\n    padding: 20px;\n    overflow-y: auto;\n    flex: 1;\n    font-family: 'Poppins', sans-serif;\n    font-size: 14px;\n    line-height: 1.8;\n    color: #444;\n    -webkit-overflow-scrolling: touch;\n  }\n  .vpc-sheet-body p { margin: 0 0 12px 0; }\n  .vpc-sheet-body p:last-child { margin-bottom: 0; }\n  .vpc-sheet-body strong { color: #1a1a1a; }\n\n  /* Mobile trust badges wrapper */\n  .vpc-trust-wrapper-mobile {\n    background: rgba(52, 21, 12, 0.06);\n    border-radius: 6px;\n    padding: 16px 12px;\n    margin-top: 16px;\n  }\n\n  /* Mobile trust badges */\n  .vpc-mobile-trust-badges {\n    display: flex;\n    justify-content: space-between;\n    align-items: flex-start;\n    gap: 12px;\n    padding: 16px 12px;\n    margin-top: 4px;\n    }\n  .vpc-mob-trust-badge {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    text-align: center;\n    flex: 1;\n    gap: 6px;\n  }\n  .vpc-mob-trust-badge img {\n    width: 32px; height: 32px; object-fit: contain;\n    filter: brightness(0) saturate(100%) invert(8%) sepia(30%) saturate(3500%) hue-rotate(350deg) brightness(95%) contrast(100%);\n  }\n  .vpc-mob-trust-badge span {\n    font-family: 'Poppins', sans-serif;\n    font-size: 10px;\n    font-weight: 600;\n    color: #34150C;\n    letter-spacing: 0.02em;\n    line-height: 1.3;\n  }\n}\n</style>\n\n<!-- ===== DESKTOP: Drawer Overlay + Drawer ===== -->\n<div class=\"vpc-drawer-overlay\" id=\"vpcDrawerOverlay\"></div>\n<div class=\"vpc-drawer\" id=\"vpcDrawer\">\n  <div class=\"vpc-drawer-header\">\n    <h3 class=\"vpc-drawer-title\" id=\"vpcDrawerTitle\"></h3>\n    <button class=\"vpc-drawer-close\" id=\"vpcDrawerClose\" type=\"button\" aria-label=\"Close\">\n      <svg viewBox=\"0 0 16 16\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M12.5 3.5L3.5 12.5M3.5 3.5L12.5 12.5\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\"/></svg>\n    </button>\n  </div>\n  <div class=\"vpc-drawer-body\" id=\"vpcDrawerBody\"></div>\n</div>\n\n<!-- ===== DESKTOP: Accordion Tabs ===== -->\n<div class=\"vpc-desktop-accordion\">\n  <div class=\"vpc-accordion-item\" data-drawer-tab=\"description\"><button class=\"vpc-accordion-header\" type=\"button\"><span>Description</span><svg class=\"vpc-accordion-chevron\" viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M2 4L6 8L10 4\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></button></div>\n  <div class=\"vpc-accordion-item\" data-drawer-tab=\"included\"><button class=\"vpc-accordion-header\" type=\"button\"><span>What's Included</span><svg class=\"vpc-accordion-chevron\" viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M2 4L6 8L10 4\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></button></div>\n  <div class=\"vpc-accordion-item\" data-drawer-tab=\"ingredients\"><button class=\"vpc-accordion-header\" type=\"button\"><span>Ingredients</span><svg class=\"vpc-accordion-chevron\" viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M2 4L6 8L10 4\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></button></div>\n  <div class=\"vpc-accordion-item\" data-drawer-tab=\"burntime\"><button class=\"vpc-accordion-header\" type=\"button\"><span>Burn Time</span><svg class=\"vpc-accordion-chevron\" viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M2 4L6 8L10 4\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></button></div>\n  <div class=\"vpc-accordion-item\" data-drawer-tab=\"howtouse\"><button class=\"vpc-accordion-header\" type=\"button\"><span>How to Use</span><svg class=\"vpc-accordion-chevron\" viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M2 4L6 8L10 4\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></button></div>\n  <div class=\"vpc-trust-wrapper\"><div class=\"vpc-desktop-trust-badges\">\n    <div class=\"vpc-trust-badge\"><img src=\"https://cdn.shopify.com/s/files/1/0920/7591/7591/files/image_5.png?v=1756754744\" alt=\"Eco-friendly\" loading=\"lazy\"><span>Refillable &<br>Eco-friendly</span></div>\n    <div class=\"vpc-trust-badge\"><img src=\"https://cdn.shopify.com/s/files/1/0920/7591/7591/files/image_4.png?v=1756754742\" alt=\"Clean Burning\" loading=\"lazy\"><span>Safe and Clean<br>Burning</span></div>\n    <div class=\"vpc-trust-badge\"><img src=\"https://cdn.shopify.com/s/files/1/0920/7591/7591/files/image_3.png?v=1756754742\" alt=\"Pet Friendly\" loading=\"lazy\"><span>Pet Friendly</span></div>\n  </div>\n  <div class=\"vpc-desktop-trust-badges\" style=\"border-top:none;padding-top:0;margin-top:12px;\">\n    <div class=\"vpc-trust-badge\"><img src=\"https://cdn.shopify.com/s/files/1/0920/7591/7591/files/free-shipping.png?v=1751615179\" alt=\"Free Shipping\" loading=\"lazy\"><span>Free Shipping<br>in US</span></div>\n    <div class=\"vpc-trust-badge\"><img src=\"https://cdn.shopify.com/s/files/1/0920/7591/7591/files/leaves.png?v=1751615389\" alt=\"Plant Based\" loading=\"lazy\"><span>100% Plant<br>Based Wax</span></div>\n    <div class=\"vpc-trust-badge\"><img src=\"https://cdn.shopify.com/s/files/1/0920/7591/7591/files/fire.png?v=1751615179\" alt=\"Long Lasting\" loading=\"lazy\"><span>Long Lasting<br>Burn Time</span></div>\n  </div></div>\n</div>\n\n<!-- ===== MOBILE: Bottom Sheet Overlay + Sheet ===== -->\n<div class=\"vpc-mobile-sheet-overlay\" id=\"vpcSheetOverlay\"></div>\n<div class=\"vpc-mobile-sheet\" id=\"vpcSheet\">\n  <div class=\"vpc-sheet-handle\"></div>\n  <div class=\"vpc-sheet-header\">\n    <h3 class=\"vpc-sheet-title\" id=\"vpcSheetTitle\"></h3>\n    <button class=\"vpc-sheet-close\" id=\"vpcSheetClose\" type=\"button\" aria-label=\"Close\">\n      <svg viewBox=\"0 0 16 16\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M12.5 3.5L3.5 12.5M3.5 3.5L12.5 12.5\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\"/></svg>\n    </button>\n  </div>\n  <div class=\"vpc-sheet-body\" id=\"vpcSheetBody\"></div>\n</div>\n\n<!-- ===== MOBILE: Accordion Tabs ===== -->\n<div class=\"vpc-mobile-accordion\">\n  <div class=\"vpc-mob-acc-item\" data-sheet-tab=\"description\"><button class=\"vpc-mob-acc-header\" type=\"button\"><span>Description</span><svg class=\"vpc-mob-chevron\" viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M2 4L6 8L10 4\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></button></div>\n  <div class=\"vpc-mob-acc-item\" data-sheet-tab=\"included\"><button class=\"vpc-mob-acc-header\" type=\"button\"><span>What's Included</span><svg class=\"vpc-mob-chevron\" viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M2 4L6 8L10 4\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></button></div>\n  <div class=\"vpc-mob-acc-item\" data-sheet-tab=\"ingredients\"><button class=\"vpc-mob-acc-header\" type=\"button\"><span>Ingredients</span><svg class=\"vpc-mob-chevron\" viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M2 4L6 8L10 4\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></button></div>\n  <div class=\"vpc-mob-acc-item\" data-sheet-tab=\"burntime\"><button class=\"vpc-mob-acc-header\" type=\"button\"><span>Burn Time</span><svg class=\"vpc-mob-chevron\" viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M2 4L6 8L10 4\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></button></div>\n  <div class=\"vpc-mob-acc-item\" data-sheet-tab=\"howtouse\"><button class=\"vpc-mob-acc-header\" type=\"button\"><span>How to Use</span><svg class=\"vpc-mob-chevron\" viewBox=\"0 0 12 12\" fill=\"none\"><path d=\"M2 4L6 8L10 4\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/></svg></button></div>\n  <div class=\"vpc-trust-wrapper-mobile\"><div class=\"vpc-mobile-trust-badges\">\n    <div class=\"vpc-mob-trust-badge\"><img src=\"https://cdn.shopify.com/s/files/1/0920/7591/7591/files/image_5.png?v=1756754744\" alt=\"Eco-friendly\" loading=\"lazy\"><span>Refillable &<br>Eco-friendly</span></div>\n    <div class=\"vpc-mob-trust-badge\"><img src=\"https://cdn.shopify.com/s/files/1/0920/7591/7591/files/image_4.png?v=1756754742\" alt=\"Clean Burning\" loading=\"lazy\"><span>Safe and Clean<br>Burning</span></div>\n    <div class=\"vpc-mob-trust-badge\"><img src=\"https://cdn.shopify.com/s/files/1/0920/7591/7591/files/image_3.png?v=1756754742\" alt=\"Pet Friendly\" loading=\"lazy\"><span>Pet Friendly</span></div>\n  </div>\n  <div class=\"vpc-mobile-trust-badges\" style=\"border-top:none;padding-top:0;margin-top:6px;\">\n    <div class=\"vpc-mob-trust-badge\"><img src=\"https://cdn.shopify.com/s/files/1/0920/7591/7591/files/free-shipping.png?v=1751615179\" alt=\"Free Shipping\" loading=\"lazy\"><span>Free Shipping<br>in US</span></div>\n    <div class=\"vpc-mob-trust-badge\"><img src=\"https://cdn.shopify.com/s/files/1/0920/7591/7591/files/leaves.png?v=1751615389\" alt=\"Plant Based\" loading=\"lazy\"><span>100% Plant<br>Based Wax</span></div>\n    <div class=\"vpc-mob-trust-badge\"><img src=\"https://cdn.shopify.com/s/files/1/0920/7591/7591/files/fire.png?v=1751615179\" alt=\"Long Lasting\" loading=\"lazy\"><span>Long Lasting<br>Burn Time</span></div>\n  </div></div>\n</div>\n\n<!-- Hidden content for both drawer and sheet -->\n<div style=\"display:none\">\n  <div id=\"vpc-content-description\">\n    {{ product.description }}\n  </div>\n  <div id=\"vpc-content-included\">\n    {% if product.metafields.custom.included %}\n      {{ product.metafields.custom.included | metafield_tag }}\n    {% else %}\n      <p><strong>Premium Wax Pearls</strong> 19 oz</p>\n      <p><strong>Cotton Wicks</strong> Specially designed for a clean, consistent flame.</p>\n      <p><strong>Instruction Manual</strong> Simple steps to make the most of your pearled candle</p>\n    {% endif %}\n  </div>\n  <div id=\"vpc-content-ingredients\">\n    {% if product.metafields.custom.ingredients %}\n      {{ product.metafields.custom.ingredients | metafield_tag }}\n    {% else %}\n      <p><strong>100% Plant-Based Wax</strong> - Clean-burning, non-toxic, and free from paraffin.</p>\n      <p><strong>Premium Fragrance Oils</strong> - Thoughtfully curated for a balanced, long-lasting scent.</p>\n      <p><strong>Phthalate-Free Fragrances</strong> - Luxurious, non-toxic scents crafted to enhance your mood.</p>\n    {% endif %}\n  </div>\n  <div id=\"vpc-content-burntime\">\n    {% if product.metafields.custom.burn_time %}\n      {{ product.metafields.custom.burn_time | metafield_tag }}\n    {% else %}\n      <p><strong>19 oz Candle:</strong> Our 19 oz candles are provided with 20 wicks.</p>\n      <p>Each Wick burns for 12 hrs.</p>\n    {% endif %}\n  </div>\n  <div id=\"vpc-content-howtouse\">\n    {% if product.metafields.custom.how_to_use %}\n      {{ product.metafields.custom.how_to_use | metafield_tag }}\n    {% else %}\n      <p><strong>Trim the Wick</strong> - Before lighting, trim the wick to 1/4 inch for a clean, even burn.</p>\n      <p><strong>Burn Safely</strong> - Keep the candle on a flat, heat-resistant surface, and never leave it unattended.</p>\n    {% endif %}\n  </div>\n</div>\n\n<script>\ndocument.addEventListener('DOMContentLoaded', function() {\n  var titles = { description:'Description', included:\"What's Included\", ingredients:'Ingredients', burntime:'Burn Time', howtouse:'How to Use' };\n\n  /* ===== DESKTOP: Right drawer ===== */\n  var dOverlay = document.getElementById('vpcDrawerOverlay');\n  var drawer = document.getElementById('vpcDrawer');\n  var dTitle = document.getElementById('vpcDrawerTitle');\n  var dBody = document.getElementById('vpcDrawerBody');\n  var dClose = document.getElementById('vpcDrawerClose');\n\n  function openDrawer(tab) {\n    var el = document.getElementById('vpc-content-' + tab);\n    if (!el) return;\n    dTitle.textContent = titles[tab] || '';\n    dBody.innerHTML = el.innerHTML;\n    dOverlay.classList.add('is-visible');\n    drawer.classList.add('is-open');\n    document.body.style.overflow = 'hidden';\n  }\n  function closeDrawer() {\n    dOverlay.classList.remove('is-visible');\n    drawer.classList.remove('is-open');\n    document.body.style.overflow = '';\n  }\n  document.querySelectorAll('[data-drawer-tab]').forEach(function(item) {\n    item.addEventListener('click', function() { openDrawer(this.getAttribute('data-drawer-tab')); });\n  });\n  if (dClose) dClose.addEventListener('click', closeDrawer);\n  if (dOverlay) dOverlay.addEventListener('click', closeDrawer);\n\n  /* ===== MOBILE: Bottom sheet ===== */\n  var sOverlay = document.getElementById('vpcSheetOverlay');\n  var sheet = document.getElementById('vpcSheet');\n  var sTitle = document.getElementById('vpcSheetTitle');\n  var sBody = document.getElementById('vpcSheetBody');\n  var sClose = document.getElementById('vpcSheetClose');\n\n  function openSheet(tab) {\n    var el = document.getElementById('vpc-content-' + tab);\n    if (!el) return;\n    sTitle.textContent = titles[tab] || '';\n    sBody.innerHTML = el.innerHTML;\n    sOverlay.classList.add('is-visible');\n    sheet.classList.add('is-open');\n    document.body.style.overflow = 'hidden';\n  }\n  function closeSheet() {\n    sOverlay.classList.remove('is-visible');\n    sheet.classList.remove('is-open');\n    document.body.style.overflow = '';\n  }\n  document.querySelectorAll('[data-sheet-tab]').forEach(function(item) {\n    item.addEventListener('click', function() { openSheet(this.getAttribute('data-sheet-tab')); });\n  });\n  if (sClose) sClose.addEventListener('click', closeSheet);\n  if (sOverlay) sOverlay.addEventListener('click', closeSheet);\n\n  /* ESC key closes both */\n  document.addEventListener('keydown', function(e) {\n    if (e.key === 'Escape') { closeDrawer(); closeSheet(); }\n  });\n});\n</script>"
