        "custom_liquid": "<div style=\"text-align:center; padding: 20px;\">\n  <h2 style=\"font-size: 28px; font-weight: bold; color: #3d1b00; margin-bottom: 30px;\">What is included</h2>\n\n  <div class=\"what-included-row\" style=\"display: flex; justify-content: center; align-items: center; gap: 10px; flex-wrap: nowrap;\">\n\n    <!-- First Image - Candle -->\n    <div class=\"included-img\">\n      <div style=\"width: 100%; aspect-ratio: 1/1; overflow: hidden; border-radius: 6px;\">\n        {% if product.metafields.custom.image %}\n          <img src=\"{{ product.metafields.custom.image | image_url: width: 600 }}\" alt=\"Candle\" style=\"width: 100%; height: 100%; object-fit: cover;\">\n        {% endif %}\n      </div>\n      <p style=\"font-weight: 600; color: #3d1b00; margin-top: 8px;\">Candle</p>\n    </div>\n\n    <!-- Plus Sign -->\n    <div class=\"included-plus\">+</div>\n\n    <!-- Second Image - Wicks -->\n    <div class=\"included-img\">\n      <div style=\"width: 100%; aspect-ratio: 1/1; overflow: hidden; border-radius: 6px;\">\n        <img src=\"https://cdn.shopify.com/s/files/1/0920/7591/7591/files/3_1_163653f2-4245-4341-b516-9402f0889ce0.png?v=1754577023\" alt=\"Wicks\" style=\"width: 100%; height: 100%; object-fit: cover;\">\n      </div>\n      <p style=\"font-weight: 600; color: #3d1b00; margin-top: 8px;\">Wicks</p>\n    </div>\n\n  </div>\n</div>\n\n<style>\n  .included-img {\n    flex: 1;\n    max-width: 210px;\n  }\n  .included-plus {\n    font-size: 20px;\n    font-weight: normal;\n    color: #8b5e3c;\n    line-height: 1;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n\n  @media (max-width: 768px) {\n    .what-included-row {\n      gap: 6px;\n    }\n    .included-img {\n      flex: 0 0 40%;\n      max-width: none;\n    }\n    .included-plus {\n      font-size: 16px;\n    }\n  }\n</style>",
