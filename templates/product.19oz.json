        "custom_liquid_33kEK3": {
          "type": "custom_liquid",
          "disabled": true,
          "settings": {
            "custom_liquid": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Mobile Secure Checkout Block</title>\n    <style>\n        /* Mobile-only styles */      \n        .mobile-secure-checkout {\n            display: none;\n            text-align: center;\n            padding: 0;\n            background-color: #FAEAD3A6;\n            font-family: 'Poppins', sans-serif;\n            margin: 0;\n        }\n        \n        .secure-text {\n            font-size: 15px;\n            color: #2c2c2c;\n            margin: 0 0 8px 0;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            gap: 6px;\n            font-weight: 400;\n        }\n        \n        .lock-icon {\n            width: auto;\n            height: auto;\n            vertical-align: middle;\n        }\n        \n        .separator-line {\n            width: 100%;\n            height: 1px;\n            background-color: #2c2c2c;\n            margin: 0;\n            opacity: 0.6;\n        }\n        \n        /* Show only on mobile devices */\n        @media only screen and (max-width: 768px) {\n            .mobile-secure-checkout {\n                display: block;\n            }\n        }\n        \n        /* Hide on desktop */\n        @media only screen and (min-width: 769px) {\n            .mobile-secure-checkout {\n                display: none;\n            }\n        }\n    </style>\n</head>\n<body>\n    <div class=\"mobile-secure-checkout\">\n        <div class=\"secure-text\">\n            we commit a secure checkout\n            <img src=\"https://cdn.shopify.com/s/files/1/0920/7591/7591/files/Vector_bb28a8d2-7273-4f6a-9fd3-6c7057137a65.png?v=1753979673\" \n                 alt=\"Secure Lock Icon\" \n                 class=\"lock-icon\">\n        </div>\n        <div class=\"separator-line\"></div>\n    </div>\n</body>\n</html>"
          }
