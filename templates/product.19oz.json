div>\n      <div class=\"vpc-reel-card-19\"><video class=\"vpc-reel-video-19\" autoplay muted loop playsinline><source src=\"https://cdn.shopify.com/videos/c/o/v/2e8b7510c8ae4741ac81cc69d8db5724.mov\" type=\"video/mp4\"></video></div>\n      <div class=\"vpc-reel-card-19\"><video class=\"vpc-reel-video-19\" autoplay muted loop playsinline><source src=\"https://cdn.shopify.com/videos/c/o/v/b62025c09ece4ee58e558f9cca084a5b.mov\" type=\"video/mp4\"></video></div>\n      <div class=\"vpc-reel-card-19\"><video class=\"vpc-reel-video-19\" autoplay muted loop playsinline><source src=\"https://cdn.shopify.com/videos/c/o/v/0632d8c745c6432ab1f021c2be605103.mp4\" type=\"video/mp4\"></video></div>\n      <div class=\"vpc-reel-card-19\"><video class=\"vpc-reel-video-19\" autoplay muted loop playsinline><source src=\"https://cdn.shopify.com/videos/c/o/v/c2cd876ab0144961b7579606c2a8f7fb.mp4\" type=\"video/mp4\"></video></div>\n      <div class=\"vpc-reel-card-19\"><video class=\"vpc-reel-video-19\" autoplay muted loop playsinline><source src=\"https://cdn.shopify.com/videos/c/o/v/a2d3183688a644ffa3ac5122312024e9.mp4\" type=\"video/mp4\"></video></div>\n    </div>\n  </div>\n</div>",
