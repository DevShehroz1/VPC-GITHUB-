            "custom_liquid": "<div class=\"ld-counter-wrap ld-counter-pd-page\">\n  <div class=\"time-group\">\n\n      <span>\n      <button class=\"copy-btn\" data-text=\"VIBES10\">\n        VIBES10\n        <img\n          alt=\"copy-icon\"\n          class=\"festive-offer-icon\"\n          src=\"https://cdn.shopify.com/s/files/1/0722/8106/3702/files/copy-icon.svg?v=1733567521\"\n        >\n      </button>\n      </span>\n\n      <div class=\"savings\" style=\"display:none;\">\n        <span class=\"label label--highlight time-save yellow\">10% OFF</span>\n      </div>\n\n      <div class=\"timer\">\n        <p>Use Code:<span class=\"yellow-bold\"> \"VIBES10\"</span> for Extra 10% discount</p>\n        <ul class=\"front\" style=\"display:none\">\n          <li><span class=\"hoursa\">00</span>h</li>\n          <li><span class=\"minutesa\">00</span>m</li>\n          <li><span class=\"secondsa\">00</span>s</li>\n        </ul>\n      </div>\n\n  </div>\n</div>\n\n<style>\n.product-meta__label-list.label-list {\n  display: none;\n}\n\n/* Shine animation */\n.ld-counter-pd-page:after {\n  content: \"\";\n  width: 30px;\n  height: 100px;\n  position: absolute;\n  left: -20px;\n  top: 0;\n  margin-top: -20px;\n  background: #fff;\n  opacity: .8;\n  filter: blur(20px);\n  animation: login-blur 1.6s infinite;\n  transform-origin: top;\n  overflow:hidden;\n}\n\n@keyframes login-blur{\n  0%{transform:translate(0) rotate(45deg)}\n  to{transform:translateX(500px) rotate(45deg)}\n}\n\n.ld-counter-wrap.ld-counter-pd-page {\n  margin-top: 0;\n  margin-bottom: 6px;\n  position:relative;\n  overflow:hidden;\n}\n\n/* Main Banner */\n.ld-counter-pd-page .time-group {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  gap: 1rem;\n  width: 100%;\n  height: 40px;\n  border-radius: 6px;\n  background-color: rgb(87, 12, 173);\n  padding: 0 10px;\n  flex-direction: row-reverse;\n}\n\n.time-save {\n  background: transparent;\n  font-size: 14px;\n  white-space: nowrap;\n  color:#fff!important;\n}\n\n.timer {\n  display: flex;\n  justify-content: center;\n  align-items: center;\n  gap: 15px;\n}\n\n.yellow-bold{\n  color: #ffad00;\n  font-weight: 700;\n}\n\n/* ✅ Smaller Yellow Copy Block */\n.copy-btn {\n  background-color: #ffad00;\n  border-radius: 4px;\n  padding: 2px 8px;\n  color: #05076f;\n  font-weight: 700;\n  cursor: pointer;\n  display: flex;\n  align-items: center;\n  gap: 4px;\n  font-size: 14px;\n  border: none;\n}\n\n/* Smaller icon */\nimg.festive-offer-icon {\n  max-width: 18px;\n  filter: invert(1);\n}\n\n.ld-counter-wrap.ld-counter-pd-page .time-group ul.front {\n  list-style: none;\n  display: flex;\n  gap: 0.5rem;\n  padding: 0;\n  margin: 0;\n  color:#fff;\n}\n\n.ld-counter-wrap.ld-counter-pd-page .time-group ul li span {\n  font-size: 20px;\n}\n\n.ld-counter-wrap.ld-counter-pd-page .time-group p {\n  margin: 0;\n  color: #fff !important;\n  font-size: 12px !important;\n}\n\n/* Mobile */\n@media (max-width: 767px) {\n  .ld-counter-pd-page .time-group {\n    height: 40px;\n    font-size: 12px;\n  }\n\n  .ld-counter-wrap.ld-counter-pd-page .time-group ul li span {\n    font-size: 16px;\n  }\n\n  .ld-counter-wrap.ld-counter-pd-page .time-group p {\n    font-size: 10px !important;\n  }\n}\n</style>\n\n<script>\nconst copyBtn = document.querySelector(\".copy-btn\");\n\ncopyBtn.addEventListener(\"click\", async () => {\n  const text = copyBtn.dataset.text;\n\n  try {\n    await navigator.clipboard.writeText(text);\n    alert(text + \" is copied!\");\n  } catch (err) {\n    console.error(\"Failed to copy text:\", err);\n  }\n});\n</script>"
