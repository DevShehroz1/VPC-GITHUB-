    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding Bottom (Mobile)",
      "min": 0,
      "max": 80,
      "step": 5,
      "default": 30,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Videos Carousel"
    }
  ]
}
{% endschema %}
