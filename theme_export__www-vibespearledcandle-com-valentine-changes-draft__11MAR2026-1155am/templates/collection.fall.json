{"sections":{"custom_liquid_PaX7wy":{"type":"custom-liquid","disabled":true,"name":"Custom Liquid","settings":{"custom_liquid":"<div class=\"section-template--24254218731869__custom_liquid_VNgj6A-padding\">\n    <div class='announcement-section-1'>\n        <div class='container'>\n            <div class='announcement-wrapper'>\n                <span class='clock-down_text'>Fall Season Sale Ends In<\/span>\n                <div class='holiday-clock' id='js-clock'>\n                    <div class='box-3'>\n                        <div class='clock-number-2' id='js-clock-days'>00<\/div>\n                        <div class='clock-label-2'>Days<\/div>\n                    <\/div>\n                    <div class='text-block-countdown'>:<\/div>\n                    <div class='box-3'>\n                        <div class='clock-number-2' id='js-clock-hours'>00<\/div>\n                        <div class='clock-label-2'>Hrs<\/div>\n                    <\/div>\n                    <div class='text-block-countdown'>:<\/div>\n                    <div class='box-3'>\n                        <div class='clock-number-2' id='js-clock-minutes'>00<\/div>\n                        <div class='clock-label-2'>Min<\/div>\n                    <\/div>\n                    <div class='text-block-countdown'>:<\/div>\n                    <div class='box-3'>\n                        <div class='clock-number-2' id='js-clock-seconds'>00<\/div>\n                        <div class='clock-label-2'>Sec<\/div>\n                    <\/div>\n                <\/div>\n            <\/div>\n        <\/div>\n    <\/div>\n\n<style>\n\/********** General Styles **********\/\n.announcement-section-1 {\n    background: linear-gradient(45deg, #8B4513, #A0522D, #33150c);\n    background-size: 400% 400%;\n    animation: primaryGradient 5s ease infinite;\n    color: #fff;\n    text-align: center;\n    padding: 10px 0;\n}\n\n.announcement-wrapper {\n    font-size: 16px;\n    font-weight: 700;\n    line-height: 19.7px;\n    letter-spacing: -0.01em;\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    gap: 16px;\n    color: #fff;\n}\n\n.holiday-clock {\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    color: #2a2552;\n    border-radius: 3px;\n}\n\n.box-3 {\n    display: flex;\n    flex-direction: column;\n    justify-content: center;\n    align-items: center;\n    background-color: #fff;\n    border-radius: 2px;\n    width: 40px;\n    height: 50px;\n    margin: 0 2px;\n    padding: 3px;\n    font-size: 12px;\n    line-height: 20px;\n}\n\n.clock-number-2 {\n    font-size: 14px;\n    font-weight: 900;\n    line-height: 1;\n}\n\n.clock-label-2 {\n    font-size: 8px;\n    line-height: 1;\n    text-transform: uppercase;\n}\n\n.text-block-countdown {\n    color: #fff;\n    padding: 0 2.5px;\n    font-weight: 800;\n}\n\n.clock-down_text {\n    color: #fff;\n}\n\n\/********** Button Styles **********\/\n.atcButton button {\n    background: #039d00 !important;\n    color: #fff;\n    padding: 5px 20px !important;\n    border-radius: 5px;\n    font-size: 13px;\n    min-height: 40px;\n}\n\n\/********** Keyframes **********\/\n@keyframes primaryGradient {\n  0% { background-position: 0% 50%; }\n  50% { background-position: 100% 50%; }\n}\n\n\/********** Media Queries **********\/\n@media (max-width: 740px) {\n    .announcement-wrapper {\n        font-size: 16px;\n        padding: 0px 0;\n        gap: 7px;\n        color: #fff;\n    }\n    .clock-number-2 {\n        font-size: 15px!important;\n        font-weight: 900;\n        line-height: 1;\n    }\n    .clock-label-2 {\n        font-size: 7px!important;\n        line-height: 1;\n        text-transform: uppercase;\n    }\n    .holiday-clock {\n        flex-wrap: wrap;\n    }\n    .box-3 {\n        width: 30px;\n        height: 35px;\n    }\n}\n\n@media (max-width: 379px) {\n    .announcement-wrapper {\n        font-size: 15px;\n        gap: 5px;\n        color: #fff;\n    }\n    .box-3 {\n        width: 30px;\n        height: 35px;\n    }\n    .text-block-countdown {\n        padding: 0 2px;\n    }\n}\n\n@media (max-width: 360px) {\n    .atcButton button {\n        padding-inline: 20px;\n    }\n}\n<\/style>\n\n<script>\n\/\/ Countdown Timer Script\n(function() {\n    \/\/ Set timer for 7 days from now\n    const now = new Date();\n    const endTime = new Date(now.getTime() + (7 * 24 * 60 * 60 * 1000)).getTime();\n\n    function updateTimer() {\n        const now = new Date().getTime();\n        const timeLeft = endTime - now;\n\n        if (timeLeft < 0) {\n            document.getElementById('js-clock').innerHTML = '<span>Sale Ended<\/span>';\n            return;\n        }\n\n        const days = Math.floor(timeLeft \/ (1000 * 60 * 60 * 24));\n        const hours = Math.floor((timeLeft % (1000 * 60 * 60 * 24)) \/ (1000 * 60 * 60));\n        const minutes = Math.floor((timeLeft % (1000 * 60 * 60)) \/ (1000 * 60));\n        const seconds = Math.floor((timeLeft % (1000 * 60)) \/ 1000);\n\n        document.getElementById('js-clock-days').textContent = String(days).padStart(2, '0');\n        document.getElementById('js-clock-hours').textContent = String(hours).padStart(2, '0');\n        document.getElementById('js-clock-minutes').textContent = String(minutes).padStart(2, '0');\n        document.getElementById('js-clock-seconds').textContent = String(seconds).padStart(2, '0');\n    }\n\n    setInterval(updateTimer, 1000);\n    updateTimer(); \/\/ Initial call\n})();\n<\/script>\n<\/div>","layout":"t4s-container-fluid","cl_bg":"","cl_bg_gradient":"","mg":",,50px,","pd":"","mg_tb":"","pd_tb":"","mg_mb":",,30px,","pd_mb":""}},"custom_liquid_nNpbbm":{"type":"custom-liquid","name":"Custom Liquid","settings":{"custom_liquid":"<style>\n  @media (min-width: 768px) {\n    .info-section-mobile {\n      display: none;\n    }\n  }\n\n  @media (max-width: 767px) {\n    .info-section-mobile {\n      border-top: 1px solid #3C1E1E;\n      border-bottom: 1px solid 