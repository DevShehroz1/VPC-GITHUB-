ortant;\n        }\n\n        .hero::before {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: 0;\n            right: 0;\n            bottom: 0;\n            background: radial-gradient(circle at 30% 70%, rgba(255, 107, 0, 0.1) 0%, transparent 50%),\n                        radial-gradient(circle at 80% 20%, rgba(183, 255, 0, 0.08) 0%, transparent 50%);\n            pointer-events: none;\n        }\n\n        .hero-content {\n            position: relative;\n            z-index: 2;\n            max-width: 800px;\n        }\n\n        .hero-pumpkin-img {\n            width: 440px; \/* doubled size *\/\n            height: auto;\n            display: block;\n            margin: 0 auto 1rem auto;\n            filter: drop-shadow(0 0 20px rgba(255, 107, 0, 0.6));\n            animation: float 3s ease-in-out infinite;\n        }\n\n        .hero-eyebrow {\n            font-family: var(--font-eater);\n            font-size: 2rem;\n            color: var(--color-slime);\n            margin-bottom: 1rem;\n            text-shadow: 0 0 15px var(--color-slime);\n            animation: float 3s ease-in-out infinite;\n        }\n\n        .hero-title {\n            font-family: var(--font-horror);\n            font-size: clamp(3rem, 9vw, 6.5rem);\n            color: var(--color-ghost);\n            margin-bottom: 1.5rem;\n            text-shadow: 0 0 30px var(--color-pumpkin), 0 0 60px var(--color-pumpkin);\n            animation: titleGlow 3s ease-in-out infinite alternate;\n        }\n\n        @keyframes titleGlow {\n            from { text-shadow: 0 0 30px var(--color-pumpkin), 0 0 60px var(--color-pumpkin); }\n            to { text-shadow: 0 0 50px var(--color-pumpkin), 0 0 80px var(--color-pumpkin), 0 0 100px var(--color-pumpkin); }\n        }\n\n        .hero-subtitle {\n            font-family: var(--font-chiller);\n            font-size: 2.05rem; \/* ~1.8rem + 4px *\/\n            color: color-mix(in oklab, var(--color-ghost) 85%, #999 15%);\n            margin-bottom: 3rem;\n            line-height: 1.4;\n        }\n\n        .hero-cta {\n            display: flex;\n            gap: 2rem;\n            justify-content: center;\n            flex-wrap: wrap;\n        }\n\n        .btn {\n            display: inline-flex;\n            align-items: center;\n            justify-content: center;\n            gap: 0.5rem;\n            padding: 0.9rem 1.75rem; \/* decreased size *\/\n            border-radius: 999px;\n            text-decoration: none;\n            font-weight: 700;\n            font-size: 1.1rem; \/* decreased size *\/\n            font-family: var(--font-chiller);\n            transition: all 0.3s ease;\n            position: relative;\n            overflow: hidden;\n        }\n\n        .btn-primary {\n            background: linear-gradient(45deg, var(--color-pumpkin), #ff8c00);\n            color: var(--color-midnight);\n            box-shadow: 0 0 30px rgba(255, 107, 0, 0.6);\n            border: 2px solid var(--color-pumpkin);\n        }\n\n        .btn-primary:hover {\n            transform: translateY(-3px) scale(1.05);\n            box-shadow: 0 0 50px rgba(255, 107, 0, 0.8), 0 0 80px rgba(255, 107, 0, 0.4);\n        }\n\n        .btn-secondary {\n            background: transparent;\n            color: var(--color-ghost);\n            border: 2px solid var(--color-ghost);\n            box-shadow: 0 0 20px rgba(255, 255, 255, 0.2);\n        }\n\n        .btn-secondary:hover {\n            background: var(--color-ghost);\n            color: var(--color-midnight);\n            transform: translateY(-3px);\n            box-shadow: 0 0 30px rgba(255, 255, 255, 0.4);\n        }\n\n        .btn::before {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: -100%;\n            width: 100%;\n            height: 100%;\n            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);\n        