<style>
    .ft-slider-item .ft-slider__item-info > a{
        overflow: visible;
        white-space: pre-wrap;
    }

    @media (max-width: 768px) {
    .ft-gift__list-wrapper .ft-gift__list{
            justify-content: center;
        }
    }
</style>

<script>
document.addEventListener("DOMContentLoaded", () => {  
  (() => {
    function _fixFtFastClick() {
      const FIXED_CLASS = "needsclick";
      const FIXED_ATTR = "data-ft-fixed";
      const FT_LABEL_SELECTOR = ".fether-widget label";
      const isBundle =
        (typeof window?._fetherStoreAppEmbed != "undefined" && window?._fetherStoreAppEmbed) ||
        (typeof window?._fetherStoreAppBlock != "undefined" && window?._fetherStoreAppBlock);
      if (!isBundle) return;
      const preventFastClick = (labels) => {
        if (labels.length === 0) return;
        labels.forEach((label) => {
          if (!label.hasAttribute(FIXED_ATTR)) {
            label.setAttribute(FIXED_ATTR, "true");
            label.classList.add(FIXED_CLASS);
            label.querySelectorAll("*").forEach((child) => {
              child.style.pointerEvents = "none";
            });
          }
        });
      };
      const labels = document.querySelectorAll(FT_LABEL_SELECTOR);
      preventFastClick(labels);
      const observer = new MutationObserver((mutations) => {
        mutations.forEach((mutation) => {
          mutation.addedNodes.forEach((node) => {
            if (node.nodeType !== Node.ELEMENT_NODE) return;
            if (node.matches(FT_LABEL_SELECTOR)) {
              preventFastClick([node]);
            }
            const newLabels = node.querySelectorAll(FT_LABEL_SELECTOR);
            if (newLabels.length > 0) {
              preventFastClick(newLabels);
            }
          });
        });
      });
      observer.observe(document.body, {
        childList: true,
        subtree: true,
      });
    }
    _fixFtFastClick();
  })();
});
</script>