<style>
    .ft-slider-item .ft-slider__item-info > a{
        overflow: visible;
        white-space: pre-wrap;
    }

    @media (max-width: 768px) {
    .ft-gift__list-wrapper .ft-gift__list{
            justify-content: center;
        }
    }
</style>

<script>
   (() => {
  const FIXED_CLASS = "needsclick";
  const FIXED_ATTR = "data-ft-fixed";
  const FT_LABEL_SELECTOR = ".fether-widget label";

  const isBundle =
    window?._fetherStoreAppEmbed ||
    window?._fetherStoreAppBlock;

  if (!isBundle) return;

  function fixLabel(label) {
    if (label.hasAttribute(FIXED_ATTR)) return;

    label.setAttribute(FIXED_ATTR, "true");
    label.classList.add(FIXED_CLASS);

    // Chỉ disable pointer-events cho child interactive thôi
    label.querySelectorAll("button, span, div, svg, img").forEach((child) => {
      child.style.pointerEvents = "none";
    });
  }

  function scanAndFix(root = document) {
    const labels = root.querySelectorAll(FT_LABEL_SELECTOR);
    labels.forEach(fixLabel);
  }

  // Initial run
  scanAndFix();

  // Optimize observer (debounce)
  let timeout;
  const observer = new MutationObserver(() => {
    clearTimeout(timeout);
    timeout = setTimeout(() => {
      scanAndFix();
    }, 100);
  });

  observer.observe(document.body, {
    childList: true,
    subtree: true,
  });
})();
</script>