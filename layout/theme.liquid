<script>
document.addEventListener('DOMContentLoaded', () => {
  document.addEventListener('cart:updated', refreshDrawer);
  document.addEventListener('cart:change', refreshDrawer);
  document.addEventListener('ajaxProduct:added', refreshDrawer);
  document.addEventListener('addToCart', refreshDrawer);

  function refreshDrawer() {
    fetch(`${routes.cart_url}?sections=cart-drawer`)
      .then(res => res.json())
      .then(data => {
        const newDrawer = new DOMParser()
          .parseFromString(data['cart-drawer'], 'text/html')
          .querySelector('#cart-drawer');

        const existing = document.querySelector('#cart-drawer');
        if (existing && newDrawer) existing.replaceWith(newDrawer);
      });
  }
});
</script>


