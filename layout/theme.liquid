<!-- Open the iCart drawer instead of theme drawer when clicking on quick add to cart from collection page. -->
<script type="text/javascript">
// Attach click handler once for all "Add to Cart" buttons
const attachAddToCartListeners = () => {
    const buttons = document.querySelectorAll('.t4s-product-btns .t4s-pr-addtocart');

    buttons.forEach(btn => {
        if (!btn.classList.contains('myicartAddBtn')) {
            btn.classList.add('myicartAddBtn');

            btn.addEventListener('click', async (e) => {
                e.preventDefault();
                e.stopImmediatePropagation(); // Prevent default theme behavior

                const variantId = btn.getAttribute('data-variant-id');
                if (!variantId) {
                    console.log('No data-variant-id found.');
                    return;
                }

                try {
                    btn.disabled = true;

                    // Step 1: Add product to cart
                    const addResponse = await fetch('/cart/add.js', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json',
                            'Accept': 'application/json',
                        },
                        body: JSON.stringify({ id: variantId, quantity: 1 })
                    });

                    const addData = await addResponse.json();
                    console.log('Product added to cart:', addData);

                    // Step 2: Update cart count
                    updateCartItemCount();

                    const monster_active = !!document.querySelector('script[src*="/cart_renderer."]');
                    if(monster_active) {
                      if(window.openCart) {
                        return monster_refresh();
                      } else {
                        return setTimeout(() => {
                          monster_refresh();
                        }, 2000);
                      }
                    }

                    // Step 3: Trigger iCart cart drawer AFTER product is added
                    if (typeof window.prepareDataForDisplayWidgetByRule === 'function') {
                        window.prepareDataForDisplayWidgetByRule();
                        console.log('iCart drawer opened after product was added');
                    }

                } catch (err) {
                    console.log('Error during add-to-cart flow:', err);
                } finally {
                    btn.disabled = false;
                }
            });
        }
    });
};

// Run the listener attachment continuously (for dynamic content)
const icartSupportInterval = setInterval(attachAddToCartListeners, 1000);

// Sticky ATC handler
const attachStickyATCListener = () => {
  const stickyBtn = document.querySelector('.t4s-sticky-atc__btns .t4s-sticky-atc__atc');

  if (stickyBtn && !stickyBtn.classList.contains('icartStickyBound')) {
    stickyBtn.classList.add('icartStickyBound');

    stickyBtn.addEventListener('click', async (e) => {
      e.preventDefault();
      e.stopImmediatePropagation();

      const variantId = stickyBtn.getAttribute('data-variant-id');
      if (!variantId) {
        console.warn('No data-variant-id found on sticky ATC button.');
        return;
      }

      try {
        stickyBtn.disabled = true;

        // Add product to cart
        const response = await fetch('/cart/add.js', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json',
          },
          body: JSON.stringify({ id: variantId, quantity: 1 })
        });

        const result = await response.json();
        console.log('Sticky ATC: Product added to cart:', result);

        // Update cart icon count
        updateCartItemCount();

        const monster_active = !!document.querySelector('script[src*="/cart_renderer."]');
        if(monster_active) {
          if(window.openCart) {
            return monster_refresh();
          } else {
            return setTimeout(() => {
              monster_refresh();
            }, 2000);
          }
        }

        // Open iCart cart drawer after product is added
        if (typeof window.prepareDataForDisplayWidgetByRule === 'function') {
          window.prepareDataForDisplayWidgetByRule();
        }

      } catch (err) {
        console.error('Sticky ATC: Failed to add product to cart:', err);
      } finally {
        stickyBtn.disabled = false;
      }
    });
  }
};

// Run every 1s to support dynamic loading
const stickyCheckInterval = setInterval(attachStickyATCListener, 1000);

// Update Cart Count Function
function updateCartItemCount() {
    fetch('/cart.js')
        .then(res => res.json())
        .then(cart => {
            const countBox = document.querySelector('.t4s-site-nav__cart .t4s-icon-cart__wrap .t4s-count-box');
            if (countBox) {
                countBox.textContent = cart.item_count.toString(); // Always show count, even if 0
            }
        })
        .catch(err => {
            console.log('Failed to fetch cart for count:', err);
        });
}

// Optional: Update count when iCart fires events
["icartAddToCartEvent", "icartUpdateCartEvent", "icartSideCartOpenEvent"].forEach((event) => {
    window.addEventListener(event, () => {
        updateCartItemCount();
    });
});
</script>
